<%#
  Form do profile do usuário autenticado.
  Como a rota é singular (resource :profile), o form sempre faz
  PATCH para profile_path — não há :id, pois o controller já
  resolve @profile = current_user.profile.
%>
<%= form_with(model: profile, url: edit_profile_path, method: :patch, class: "space-y-8") do |form| %>

  <% if profile.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-600 px-4 py-3 text-sm font-medium rounded-xl">
      <h2><%= pluralize(profile.errors.count, "error") %> prohibited this profile from being saved:</h2>
      <ul class="list-disc ml-5 mt-1.5 space-y-0.5">
        <% profile.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Seção: Sobre ── %>
  <section>
    <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-4">About</h3>

    <%= form.label :headline, "Profissão | Vocação", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.text_field :headline,
          placeholder: "Editor de vídeo, Desenvolvedor, Melhorador de textos, (pode escrever mais)...",
          class: field_classes(profile, :bio) %>
    <p class="text-xs text-slate-400 mt-1.5">Uma pequena descrição de suas habilidades</p>
  </section>

  <section>
    <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-4">About</h3>

    <%= form.label :bio, "Bio", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.text_area :bio, rows: 4,
          placeholder: "Tell people a bit about yourself…",
          class: field_classes(profile, :bio) %>
    <p class="text-xs text-slate-400 mt-1.5">A short summary that appears at the top of your profile.</p>
  </section>

  <hr class="border-slate-100">

  <%# ── Seção: Educação ── %>
  <section>
    <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-4">Education</h3>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= form.label :course, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <%= form.text_field :course,
              placeholder: "e.g. Computer Science",
              class: field_classes(profile, :course) %>
      </div>

      <div>
        <%= form.label :institution, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <%= form.text_field :institution,
              placeholder: "e.g. UFPB",
              class: field_classes(profile, :institution) %>
      </div>
    </div>
  </section>

  <hr class="border-slate-100">

  <%# ── Seção: Links sociais ── %>
  <section>
    <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-4">Social links</h3>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= form.label :github, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 absolute left-3.5 top-1/2 -translate-y-1/2" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.42-1.305.763-1.605-2.665-.303-5.467-1.332-5.467-5.93 0-1.31.467-2.382 1.236-3.222-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.302 1.23A11.5 11.5 0 0112 5.803c1.02.005 2.047.138 3.005.404 2.292-1.552 3.3-1.23 3.3-1.23.653 1.653.242 2.873.119 3.176.77.84 1.235 1.912 1.235 3.222 0 4.61-2.807 5.624-5.479 5.92.43.372.823 1.103.823 2.222 0 1.606-.015 2.898-.015 3.293 0 .322.216.696.825.578C20.566 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
          <%= form.text_field :github,
                placeholder: "github.com/username",
                class: field_classes(profile, :github, with_icon: true) %>
        </div>
      </div>

      <div>
        <%= form.label :linkedin, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 absolute left-3.5 top-1/2 -translate-y-1/2" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 110-4.123 2.062 2.062 0 010 4.123zM7.114 20.452H3.558V9h3.556v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <%= form.text_field :linkedin,
                placeholder: "linkedin.com/in/username",
                class: field_classes(profile, :linkedin, with_icon: true) %>
        </div>
      </div>
    </div>
  </section>

  <%# ── Ações ── %>
  <div class="flex items-center justify-end gap-3 pt-2 border-t border-slate-100">
    <%= link_to "Cancel", root_path,
          class: "px-5 py-2.5 text-sm font-medium text-slate-600 hover:text-slate-900 transition" %>
    <%= form.submit "Save changes",
          class: "px-5 py-2.5 bg-indigo-500 hover:bg-indigo-600 active:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition cursor-pointer shadow-sm shadow-indigo-200" %>
  </div>
<% end %>