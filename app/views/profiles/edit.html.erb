<% content_for :title, "Edit profile · FreelaHub" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">

  <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-6 lg:gap-8 items-start">

    <%# ══════════════════════════════════════════ %>
    <%# Coluna esquerda — card de identidade visual %>
    <%# ══════════════════════════════════════════ %>
    <div class="bg-white rounded-2xl border border-slate-200 p-6 lg:sticky lg:top-24">
      <div class="flex flex-col items-center text-center">

        <%# Avatar com iniciais — sem upload real por ora %>
        <div class="relative">
          <div class="w-24 h-24 rounded-full bg-linear-to-br from-indigo-400 to-indigo-600 flex items-center justify-center shadow-sm">
            <span class="text-white text-2xl font-semibold tracking-wide">
              <%= @profile.initials %>
            </span>
          </div>

          <%# Indicador de "trocar foto" — visual apenas, sem funcionalidade de upload %>
          <button type="button"
                  title="Photo upload coming soon"
                  disabled
                  class="absolute -bottom-1 -right-1 w-8 h-8 rounded-full bg-white border border-slate-200 flex items-center justify-center text-slate-400 cursor-not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/>
            </svg>
          </button>
        </div>

        <h2 class="font-semibold text-slate-900 mt-4">
          <%= current_user.full_name.presence || current_user.email %>
        </h2>
        <p class="text-sm text-slate-500 mt-0.5">
          <%= @profile.course.presence || current_user.role.to_s.titleize %>
        </p>

        <span class="mt-3 inline-flex items-center px-2.5 py-1 rounded-full bg-indigo-50 text-indigo-600 text-xs font-medium">
          <%= current_user.role.titleize %>
        </span>
      </div>

      <div class="border-t border-slate-100 mt-6 pt-5 space-y-3 text-sm text-slate-500">
        <p class="flex items-start gap-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
          <span class="truncate"><%= current_user.email %></span>
        </p>
      </div>
      <%= button_to "Sair",
        destroy_user_session_path,
        method: :delete,
        class: "w-full bg-red-500 text-white px-4 py-2 rounded mt-5 font-semibold cursor-pointer" %>
    </div>

    <%# ══════════════════════════════════════════ %>
    <%# Coluna direita — formulário                 %>
    <%# ══════════════════════════════════════════ %>
    <div class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-8">
      <h1 class="text-xl font-semibold text-slate-900">Edit profile</h1>
      <p class="text-sm text-slate-500 mt-1 mb-7">
        This information will be visible to people viewing your public profile.
      </p>

      <%= render "form", profile: @profile %>
    </div>

  </div>

  <%# ══════════════════════════════════════════ %>
  <%# Skills — submissão separada do form principal %>
  <%# ══════════════════════════════════════════ %>
  <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-6 lg:gap-8 mt-6">
    <div class="hidden lg:block"></div> <%# alinha com a coluna do form acima %>

    <div class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-8">
      <h2 class="text-xl font-semibold text-slate-900">Skills</h2>
      <p class="text-sm text-slate-500 mt-1 mb-6">
        Add the skills that best represent your experience.
      </p>

      <%# Tags das skills já atribuídas %>
      <% if @profile.skills.any? %>
        <div class="flex flex-wrap gap-2 mb-6">
          <% @profile.skills.each do |skill| %>
            <span class="inline-flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-full bg-indigo-50 text-indigo-700 text-sm font-medium">
              <%= skill.name %>
              <%= button_to profile_skill_path(skill), method: :delete,
                    form: { data: { turbo_confirm: "Remove #{skill.name} from your profile?" } },
                    class: "text-indigo-400 hover:text-indigo-700 transition leading-none" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              <% end %>
            </span>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-400 mb-6">No skills added yet.</p>
      <% end %>

      <%# Form de adicionar nova skill, com sugestões via datalist %>
      <%= form_with url: profile_skills_path, method: :post, class: "flex gap-3" do |f| %>
        <div class="flex-1">
          <%= f.text_field :skill_name,
                list: "skills-suggestions",
                placeholder: "e.g. Ruby on Rails",
                autocomplete: "off",
                class: "w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-900 placeholder-slate-400 bg-slate-50 focus:outline-none focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400 focus:bg-white transition" %>

          <%# Lista de sugestões nativa do browser, alimentada pelas skills já cadastradas %>
          <datalist id="skills-suggestions">
            <% Skill.order(:name).pluck(:name).each do |name| %>
              <option value="<%= name %>"></option>
            <% end %>
          </datalist>
        </div>

        <%= f.submit "Adicionar",
              class: "px-5 py-2.5 bg-indigo-500 hover:bg-indigo-600 active:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition cursor-pointer shrink-0" %>
      <% end %>
    </div>
  </div>
</div>