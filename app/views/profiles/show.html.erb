<% content_for :title, "My profile · FreelaHub" %>

<div class="max-w-2xl mx-auto px-6 py-10">

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900 tracking-tight">My profile</h1>
    <%= link_to "Edit profile", edit_profile_path, class: "text-sm text-indigo-500 font-semibold hover:text-indigo-700 transition" %>
  </div>

  <div class="bg-white rounded-2xl border border-slate-200 p-8 space-y-5">
    <div>
      <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Bio</p>
      <p class="text-sm text-slate-700"><%= @profile.bio.presence || "—" %></p>
    </div>

    <div class="grid grid-cols-2 gap-5">
      <div>
        <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Course</p>
        <p class="text-sm text-slate-700"><%= @profile.course.presence || "—" %></p>
      </div>
      <div>
        <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Institution</p>
        <p class="text-sm text-slate-700"><%= @profile.institution.presence || "—" %></p>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-5">
      <div>
        <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">GitHub</p>
        <p class="text-sm text-slate-700"><%= @profile.github.presence || "—" %></p>
      </div>
      <div>
        <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">LinkedIn</p>
        <p class="text-sm text-slate-700"><%= @profile.linkedin.presence || "—" %></p>
      </div>
    </div>
  </div>

</div>