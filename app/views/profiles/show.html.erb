<% content_for :title, "#{@profile.user.full_name.presence || @profile.user.name} · FreelaHub" %>

<div class="min-h-screen bg-slate-100 py-8 px-6">
  <div class="max-w-7xl mx-auto space-y-4">

    <%# ── Card principal: banner + identidade ── %>
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="h-36 bg-[#1a2560]"></div>

      <div class="px-8 pb-7">
        <div class="flex items-end justify-between -mt-10 mb-4">
          <div class="w-20 h-20 rounded-2xl border-4 border-white bg-[#2E3BBF] flex items-center justify-center text-white text-3xl font-medium shrink-0">
            <%= ((@profile.user.full_name.presence || @profile.user.name) || "?").first(2).upcase %>
          </div>
          

          <% if user_signed_in? && current_user.username == @profile.user.username %>
            <div class="flex gap-2">
              <%= link_to edit_profile_path,
                      class: "inline-flex items-center gap-2 text-sm font-medium text-indigo-600 border border-indigo-300 hover:bg-indigo-50 transition rounded-full px-5 py-2" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                  Editar perfil
              <% end %>
              <%= button_to destroy_user_session_path,
                      method: :delete,
                      class: "inline-flex items-center gap-2 text-sm font-medium text-white bg-red-500 border border-red-700 hover:bg-red-600 transition rounded-full px-5 py-2" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
                  </svg>
                  Sair
                <% end %>
            </div>
          <% end %>
        </div>

        <h1 class="text-2xl font-semibold text-slate-900 leading-tight">
          <%= @profile.user.full_name.presence || @profile.user.name %>
        </h1>
        <p class="text-sm text-slate-400 mt-1 mb-3">@<%= @profile.user.username %></p>

        <% if @profile.headline.present? %>
          <p class="text-base text-slate-600 leading-relaxed mb-4 max-w-2xl"><%= @profile.headline %></p>
        <% end %>

        <% if @profile.github.present? || @profile.linkedin.present? %>
          <div class="flex flex-wrap items-center gap-5">
            <% if @profile.github.present? %>
              <%= link_to "https://github.com/#{@profile.github}", target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 transition" do %>
                <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.744 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                </svg>
                github.com/<%= @profile.github %>
              <% end %>
            <% end %>

            <% if @profile.linkedin.present? %>
              <%= link_to "https://linkedin.com/in/#{@profile.linkedin}", target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-800 transition" do %>
                <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M19 3a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14zm-.5 15.5v-5.3a3.26 3.26 0 00-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 011.4 1.4v4.93h2.79zM6.88 8.56a1.68 1.68 0 001.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 00-1.69 1.69c0 .93.76 1.68 1.69 1.68zm1.39 9.94v-8.37H5.5v8.37h2.77z"/>
                </svg>
                linkedin.com/in/<%= @profile.linkedin %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Card: Sobre + Formação ── %>
    <div class="bg-white rounded-2xl border border-slate-200">
      <div class="px-8 py-6">
        <p class="text-xs font-medium text-slate-400 uppercase tracking-widest mb-4">Sobre</p>
        <% if @profile.bio.present? %>
          <p class="text-base text-slate-600 leading-relaxed max-w-3xl"><%= @profile.bio %></p>
        <% else %>
          <p class="text-sm text-slate-400 italic">Nenhuma bio adicionada.</p>
          <% if user_signed_in? && current_user.username == @profile.user.username %>
            <%= link_to "Adicionar bio →", edit_profile_path, class: "text-sm text-indigo-500 hover:underline mt-2 inline-block" %>
          <% end %>
        <% end %>
      </div>

      <div class="border-t border-slate-100 mx-8"></div>

      <div class="px-8 py-6">
        <p class="text-xs font-medium text-slate-400 uppercase tracking-widest mb-4">Formação</p>
        <div class="grid grid-cols-2 gap-8 max-w-lg">
          <div>
            <p class="text-xs text-slate-400 mb-1.5">Curso</p>
            <p class="text-base font-medium text-slate-800"><%= @profile.course.presence || "—" %></p>
          </div>
          <div>
            <p class="text-xs text-slate-400 mb-1.5">Instituição</p>
            <p class="text-base font-medium text-slate-800"><%= @profile.institution.presence || "—" %></p>
          </div>
        </div>
      </div>
    </div>

    <%# ── Card: Portfólio / Posts ── %>
    <div class="bg-white rounded-2xl border border-slate-200">
      <div class="px-8 py-6 flex items-center justify-between">
        <p class="text-xs font-medium text-slate-400 uppercase tracking-widest">Portfólio</p>
        <span class="text-xs text-slate-400"><%= @posts.size %> <%= @posts.size == 1 ? "publicação" : "publicações" %></span>
      </div>

      <% if @posts.any? %>
        <div class="border-t border-slate-100"></div>
        <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @posts.each do |post| %>
            <div class="group rounded-xl border border-slate-200 overflow-hidden hover:border-indigo-200 hover:shadow-sm transition-all cursor-pointer">
              <% first = post.attachments.first %>
              <% if first.present? %>
                <div class="aspect-video bg-slate-100 overflow-hidden">
                  <% if first.video? %>
                    <video src="<%= rails_blob_url(first) %>" class="w-full h-full object-cover" muted preload="metadata"></video>
                  <% else %>
                    <%= image_tag rails_blob_url(first), class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: post.title %>
                  <% end %>
                </div>
              <% else %>
                <div class="aspect-video bg-slate-50 flex items-center justify-center border-b border-slate-100">
                  <svg class="w-8 h-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3 3h18M3 21h18"/>
                  </svg>
                </div>
              <% end %>

              <div class="p-4">
                <p class="text-sm font-medium text-slate-800 leading-snug line-clamp-1 mb-1"><%= post.title %></p>
                <% if post.description.present? %>
                  <p class="text-xs text-slate-500 leading-relaxed line-clamp-2"><%= post.description %></p>
                <% end %>
                <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100">
                  <span class="text-xs text-slate-400"><%= post.created_at.strftime("%d/%m/%Y") %></span>
                  <% if post.attachments.size > 1 %>
                    <span class="text-xs text-slate-400">+<%= post.attachments.size - 1 %> mídias</span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="border-t border-slate-100 px-8 py-12 flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
            </svg>
          </div>
          <p class="text-sm font-medium text-slate-600 mb-1">Nenhuma publicação ainda</p>
          <p class="text-xs text-slate-400 max-w-xs">
            Quando <%= (@profile.user.full_name.presence || @profile.user.name).split.first %> publicar projetos, eles aparecerão aqui.
          </p>
          <% if user_signed_in? && current_user.username == @profile.user.username %>
            <%= link_to new_post_path, class: "mt-4 inline-flex items-center gap-2 text-sm font-medium text-indigo-600 border border-indigo-300 hover:bg-indigo-50 transition rounded-full px-5 py-2" do %>
              Nova publicação
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# ── Card: Visitantes — só aparece pro dono ── %>
    <% if @visitors %>
      <div class="bg-white rounded-2xl border border-slate-200">
        <div class="px-8 py-6 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-xs font-medium text-slate-400 uppercase tracking-widest">Quem visitou seu perfil</p>
          </div>
          <span class="text-xs text-slate-400">
            <%= @visitors.size %> <%= @visitors.size == 1 ? "visita recente" : "visitas recentes" %>
          </span>
        </div>

        <div class="border-t border-slate-100"></div>

        <% if @visitors.any? %>
          <div class="divide-y divide-slate-100">
            <% @visitors.each do |pv| %>
              <%= link_to profile_path(pv.viewer.user.username), class: "flex items-center justify-between px-8 py-4 hover:bg-slate-50 transition group" do %>
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-xl bg-[#2E3BBF] flex items-center justify-center text-white text-sm font-medium shrink-0">
                    <%= (pv.viewer.user.full_name.presence || pv.viewer.user.name).first(2).upcase %>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-slate-800 group-hover:text-indigo-600 transition leading-tight">
                      <%= pv.viewer.user.full_name.presence || pv.viewer.user.name %>
                    </p>
                    <p class="text-xs text-slate-400 mt-0.5">@<%= pv.viewer.user.username %></p>
                  </div>
                </div>
                <span class="text-xs text-slate-400 shrink-0">
                  <%= time_ago_in_words(pv.viewed_at) %> atrás
                </span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="px-8 py-10 text-center">
            <p class="text-sm text-slate-400">Nenhuma visita ainda.</p>
            <p class="text-xs text-slate-300 mt-1">Quando alguém visitar seu perfil, aparecerá aqui.</p>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>
</div>