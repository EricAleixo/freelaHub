<% content_for :title, "My Profile · FreelaHub" %>

<div class="max-w-7xl mx-auto px-6 py-8">
  <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr_268px] gap-6 items-start">

    <%# ══════════════════════════════════════════ %>
    <%# COLUNA ESQUERDA — card de perfil           %>
    <%# ══════════════════════════════════════════ %>
    <div class="space-y-4">

      <%# Profile card %>
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-5 pb-5">
          <%# Avatar — pulls up just enough to overlap the bottom edge of the cover %>
          <div class="mt-8 mb-3">
            <div class="w-16 h-16 rounded-xl ring-[3px] ring-white bg-indigo-100 flex items-center justify-center overflow-hidden shadow-md">
              <span class="text-indigo-600 font-bold text-xl"><%= @profile.initials %></span>
            </div>
          </div>

          <h2 class="font-semibold text-slate-900 text-base leading-tight"><%= @profile.name %></h2>

          <% if @profile.headline.present? %>
            <p class="text-sm text-slate-500 mt-0.5 leading-relaxed"><%= @profile.headline %></p>
          <% else %>
            <%= link_to edit_profile_path, class: "text-sm text-indigo-400 hover:text-indigo-600 transition mt-0.5 block" do %>
              + Adicionar título profissional
            <% end %>
          <% end %>

          <% if @profile_skills.any? %>
            <div class="mt-4 pt-4 border-t border-slate-100">
              <p class="text-xs font-medium uppercase tracking-wide text-slate-400 mb-2">
                Habilidades
              </p>

              <div class="flex flex-wrap gap-2">
                <% @profile_skills.each do |skill| %>
                  <span class="inline-flex items-center rounded-full bg-indigo-50 border border-indigo-100 px-3 py-1 text-xs font-medium text-indigo-700">
                    <%= skill.name %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>

          <div class="flex items-center gap-5 mt-4 pt-4 border-t border-slate-100">
            <div>
              <p class="text-lg font-bold text-slate-900"><%= @profile_views %></p>
              <p class="text-xs text-slate-400 mt-0.5">Visitas</p>
            </div>
          </div>
        </div>
      </div>

      <%# Links card %>
      <% valid_links = @profile.links.select { |link| link[:url].present? } %>
      <% if valid_links.any? %>
        <div class="bg-white rounded-2xl border border-slate-200 p-5">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Links</p>
          <ul class="space-y-2">
            <% valid_links.each do |link| %>
              <li>
                <%= link_to link[:url], class: "flex items-center gap-2.5 hover:text-indigo-600 transition group", target: "_blank" do %>
                  <span class="w-7 h-7 rounded-lg bg-slate-50 border border-slate-200 flex items-center justify-center shrink-0 group-hover:border-indigo-200 group-hover:bg-indigo-50 transition">
                    <svg class="w-3.5 h-3.5 text-slate-400 group-hover:text-indigo-500 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 010 5.656l-3 3a4 4 0 11-5.656-5.656l1.5-1.5M10.172 13.828a4 4 0 010-5.656l3-3a4 4 0 115.656 5.656l-1.5 1.5"/>
                    </svg>
                  </span>
                  <span class="truncate text-sm text-slate-600 group-hover:text-indigo-600 transition"><%= link[:label] %></span>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% else %>
        <div class="bg-white rounded-2xl border border-dashed border-slate-200 p-5 text-center">
          <p class="text-sm text-slate-400 mb-2">Nenhum link adicionado ainda</p>
          <%= link_to edit_profile_path, class: "text-sm font-medium text-indigo-500 hover:text-indigo-700 transition" do %>
            + Adicionar link
          <% end %>
        </div>
      <% end %>

      <%# Complete profile nudge — only shown if incomplete %>
      <% incomplete = !@profile.headline.present? || valid_links.empty? %>
      <% if incomplete %>
        <div class="bg-indigo-50 rounded-2xl border border-indigo-100 p-5">
          <p class="text-sm font-semibold text-indigo-900 mb-1">Complete seu perfil</p>
          <p class="text-xs text-indigo-500 mb-3 leading-relaxed">Perfis completos recebem até 3× mais propostas.</p>
          <div class="space-y-2 mb-4">
            <% unless @profile.headline.present? %>
              <div class="flex items-center gap-2">
                <span class="w-4 h-4 rounded-full border-2 border-indigo-300 shrink-0"></span>
                <p class="text-xs text-indigo-700">Título profissional</p>
              </div>
            <% end %>
            <% if valid_links.empty? %>
              <div class="flex items-center gap-2">
                <span class="w-4 h-4 rounded-full border-2 border-indigo-300 shrink-0"></span>
                <p class="text-xs text-indigo-700">Link de portfólio ou rede</p>
              </div>
            <% end %>
          </div>
          <%= link_to edit_profile_path, class: "block text-center text-sm font-semibold px-3 py-2 rounded-xl bg-indigo-600 text-white hover:bg-indigo-700 transition" do %>
            Completar agora
          <% end %>
        </div>
      <% end %>

    </div>

    <%# ══════════════════════════════════════════ %>
    <%# COLUNA CENTRAL — posts + vagas             %>
    <%# ══════════════════════════════════════════ %>
    <div class="space-y-8 min-w-0">

      <%# ─── Showreels / Posts ─── %>
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-semibold text-slate-900">Showreels</h2>
          <% if @posts.any? %>
            <%= link_to "Ver todos →", posts_path, class: "text-sm font-medium text-indigo-500 hover:text-indigo-700 transition" %>
          <% end %>
        </div>

        <% if @posts.any? %>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <% @posts.each do |post| %>
              <%= link_to post_path(post), class: "group block" do %>
                <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:border-indigo-200 hover:shadow-sm transition-all duration-200">
                  <div class="aspect-4/3 bg-linear-to-br from-slate-100 to-indigo-50 flex items-center justify-center relative overflow-hidden">
                    <% if post.attachments.attached? %>
                      <%= image_tag post.attachments.first,
                            alt: post.title,
                            class: "w-full h-full object-cover group-hover:scale-[1.03] transition duration-300" %>
                    <% else %>
                      <svg class="w-8 h-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
                      </svg>
                    <% end %>
                    <div class="absolute inset-0 bg-indigo-900/0 group-hover:bg-indigo-900/8 transition duration-200"></div>
                  </div>
                  <div class="px-3 py-2.5">
                    <p class="text-sm font-medium text-slate-700 truncate group-hover:text-indigo-600 transition"><%= post.title %></p>
                  </div>
                </div>
              <% end %>
            <% end %>

            <%# Post now tile — always appended %>
            <%= link_to new_post_path, class: "group block" do %>
              <div class="aspect-4/3 rounded-2xl border-2 border-dashed border-slate-200 hover:border-indigo-300 bg-slate-50 hover:bg-indigo-50/50 flex flex-col items-center justify-center gap-2 transition-all duration-200">
                <div class="w-8 h-8 rounded-lg bg-white border border-slate-200 group-hover:border-indigo-300 group-hover:bg-indigo-50 flex items-center justify-center shadow-sm transition">
                  <svg class="w-4 h-4 text-slate-400 group-hover:text-indigo-500 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                  </svg>
                </div>
                <p class="text-sm text-slate-400 group-hover:text-indigo-500 transition font-medium">Poste agora!</p>
              </div>
            <% end %>
          </div>
        <% else %>
          <%# Empty state — portfolio %>
          <div class="bg-white rounded-2xl border border-dashed border-slate-300 px-8 py-12 text-center">
            <div class="w-12 h-12 rounded-2xl bg-indigo-50 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
              </svg>
            </div>
            <p class="text-sm font-semibold text-slate-700 mb-1">Nenhum projeto publicado ainda</p>
            <p class="text-sm text-slate-400 mb-5">Mostre seus trabalhos e atraia clientes. Um portfólio forte faz toda a diferença.</p>
            <%= link_to new_post_path, class: "inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-xl bg-indigo-600 text-white hover:bg-indigo-700 transition shadow-sm" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
              </svg>
              Adicionar projeto
            <% end %>
          </div>
        <% end %>
      </section>

      <%# ─── Vagas relevantes ─── %>
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-semibold text-slate-900">Explore opções para seu perfil</h2>
          <% if @jobs.any? %>
            <%= link_to "Ver todas →", jobs_path, class: "text-sm font-medium text-indigo-500 hover:text-indigo-700 transition" %>
          <% end %>
        </div>

        <% if @jobs.any? %>
          <ul class="space-y-2.5">
            <% @jobs.each do |job| %>
              <li>
                <%= link_to job_path(job), class: "group block bg-white rounded-2xl border border-slate-200 overflow-hidden hover:border-indigo-200 hover:shadow-sm transition-all duration-200" do %>
                  <div class="px-5 py-4 flex items-start justify-between gap-4">
                    <div class="flex gap-3 items-start min-w-0">
                      <div class="shrink-0 w-10 h-10 rounded-xl bg-indigo-50 border border-indigo-100 flex items-center justify-center group-hover:bg-indigo-100 transition">
                        <svg class="w-5 h-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                      </div>
                      <div class="min-w-0">
                        <p class="text-sm font-semibold text-slate-900 leading-snug group-hover:text-indigo-600 transition truncate"><%= job.title %></p>
                        <% if job.description.present? %>
                          <p class="mt-0.5 text-xs text-slate-400 line-clamp-1 leading-relaxed"><%= job.description %></p>
                        <% end %>
                      </div>
                    </div>

                    <%
                      badge = case job.status
                      when "open"   then { label: "Aberta",    cls: "bg-emerald-50 text-emerald-700 border-emerald-200" }
                      when "paused" then { label: "Pausada",   cls: "bg-amber-50 text-amber-700 border-amber-200" }
                      when "closed" then { label: "Encerrada", cls: "bg-red-50 text-red-600 border-red-200" }
                      else               { label: job.status.humanize, cls: "bg-slate-100 text-slate-600 border-slate-200" }
                      end
                    %>
                    <span class="inline-flex items-center gap-1.5 shrink-0 text-[11px] font-medium px-2.5 py-1 rounded-full border <%= badge[:cls] %>">
                      <span class="w-1.5 h-1.5 rounded-full bg-current opacity-60"></span>
                      <%= badge[:label] %>
                    </span>
                  </div>

                  <div class="grid grid-cols-3 divide-x divide-slate-100 border-t border-slate-100 bg-slate-50/60">
                    <div class="px-4 py-2.5 flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                      </svg>
                      <div>
                        <p class="text-[11px] font-semibold text-slate-800">R$ <%= number_to_currency(job.budget, unit: "", separator: ",", delimiter: ".") %></p>
                        <p class="text-[10px] text-slate-400">Orçamento</p>
                      </div>
                    </div>
                    <div class="px-4 py-2.5 flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                      </svg>
                      <div>
                        <p class="text-[11px] font-semibold text-slate-800"><%= job.proposals.count %></p>
                        <p class="text-[10px] text-slate-400">Propostas</p>
                      </div>
                    </div>
                    <div class="px-4 py-2.5 flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
                      </svg>
                      <div>
                        <p class="text-[11px] font-semibold text-slate-800"><%= l(job.created_at.to_date, format: :long) %></p>
                        <p class="text-[10px] text-slate-400">Publicada em</p>
                      </div>
                    </div>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <%# Empty state — vagas %>
          <div class="bg-white rounded-2xl border border-dashed border-slate-300 px-8 py-12 text-center">
            <div class="w-12 h-12 rounded-2xl bg-indigo-50 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="text-sm font-semibold text-slate-700 mb-1">Nenhuma vaga disponível agora</p>
            <p class="text-sm text-slate-400 mb-5">Complete suas habilidades para receber sugestões de vagas alinhadas ao seu perfil.</p>
            <%= link_to jobs_path, class: "inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-xl border border-slate-200 text-slate-700 hover:border-indigo-300 hover:text-indigo-600 transition" do %>
              Explorar todas as vagas
            <% end %>
          </div>
        <% end %>
      </section>

    </div>

    <%# ══════════════════════════════════════════ %>
    <%# COLUNA DIREITA — stats + perfis similares  %>
    <%# ══════════════════════════════════════════ %>
    <div class="space-y-4">

      <%# My stats %>
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base font-semibold text-slate-900">Minha atividade</h3>
          <span class="text-xs font-medium text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">7 dias</span>
        </div>

        <div class="grid grid-cols-2 gap-2.5 mb-4">
          <div class="bg-slate-50 rounded-xl px-3 py-3">
            <p class="text-xl font-bold text-slate-900 leading-none"><%= @profile.stats[:views] %></p>
            <p class="text-xs text-slate-400 mt-1">Visualizações</p>
          </div>
          <div class="bg-slate-50 rounded-xl px-3 py-3">
            <p class="text-xl font-bold text-slate-900 leading-none"><%= @profile.stats[:visitors] %></p>
            <p class="text-xs text-slate-400 mt-1">Visitantes únicos</p>
          </div>
        </div>

        <svg viewBox="0 0 200 52" class="w-full h-12" preserveAspectRatio="none">
          <defs>
            <linearGradient id="grad1" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#6366f1" stop-opacity="0.18"/>
              <stop offset="100%" stop-color="#6366f1" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <polygon points="0,42 33,38 66,40 100,26 133,18 166,14 200,6 200,52 0,52" fill="url(#grad1)"/>
          <polyline points="0,42 33,38 66,40 100,26 133,18 166,14 200,6"
                    fill="none" stroke="#6366f1" stroke-width="1.5"
                    stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="flex justify-between text-[10px] text-slate-400 mt-1.5">
          <span>S</span><span>T</span><span>Q</span><span>Q</span><span>S</span><span>S</span><span>D</span>
        </div>
      </div>

      <%# Perfis similares %>
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <h3 class="text-base font-semibold text-slate-900 mb-4">Perfis similares</h3>

        <% if @similar_profiles.any? %>
          <ul class="space-y-1">
            <% @similar_profiles.each do |profile| %>
              <%= link_to profile_path(profile.user.username), class: "group flex items-center gap-3 px-2 py-2 rounded-xl hover:bg-slate-50 transition -mx-2" do %>
                <div class="w-9 h-9 rounded-xl bg-indigo-100 flex items-center justify-center text-indigo-600 text-xs font-bold shrink-0">
                  <%= profile.user.full_name.split.map(&:first).first(2).join.upcase %>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-semibold text-slate-900 group-hover:text-indigo-600 transition truncate leading-snug">
                    <%= profile.user.full_name %>
                  </p>
                  <p class="text-xs text-slate-400 truncate mt-0.5">
                    <%= profile.headline.presence || "Freelancer" %>
                  </p>
                </div>
                <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-indigo-400 transition shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
                </svg>
              <% end %>
            <% end %>
          </ul>
        <% else %>
          <%# Empty state — perfis similares %>
          <div class="text-center py-5">
            <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center mx-auto mb-3">
              <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>
              </svg>
            </div>
            <p class="text-sm font-semibold text-slate-600 mb-1">Nenhum perfil encontrado</p>
            <p class="text-xs text-slate-400 leading-relaxed">Adicione habilidades para aparecer em sugestões.</p>
          </div>
        <% end %>
      </div>

    </div>

  </div>
</div>