<% content_for :title, "My Profile · FreelaHub" %>

<div class="max-w-7xl mx-auto px-6 py-8">
  <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr_280px] gap-6 items-start">

    <%# ══════════════════════════════════════ %>
    <%# Coluna esquerda — card de perfil         %>
    <%# ══════════════════════════════════════ %>
    <div class="bg-white rounded-2xl border border-slate-200 p-6">
      <div class="w-16 h-16 rounded-full bg-indigo-100 flex items-center justify-center mb-4 overflow-hidden">
        <span class="text-indigo-500 font-semibold text-lg"><%= @profile.initials %></span>
      </div>

      <h2 class="font-semibold text-slate-900"><%= @profile.name %></h2>
      <p class="text-sm text-slate-500 mt-0.5"><%= @profile.headline %></p>

      <div class="flex items-center gap-6 mt-5 pt-5 border-t border-slate-100">
        <div>
          <p class="font-semibold text-slate-900"><%= @profile.connections_count %></p>
          <p class="text-xs text-slate-400">Connections</p>
        </div>
        <div>
          <p class="font-semibold text-slate-900"><%= @profile_views %></p>
          <p class="text-xs text-slate-400">Views</p>
        </div>
      </div>

      <% valid_links = @profile.links.select { |link| link[:url].present? } %>

      <% if valid_links.any? %>
        <ul class="mt-5 pt-5 border-t border-slate-100 space-y-2.5">
          <% valid_links.each do |link| %>
            <li class="flex items-center gap-2 text-sm text-slate-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 010 5.656l-3 3a4 4 0 11-5.656-5.656l1.5-1.5M10.172 13.828a4 4 0 010-5.656l3-3a4 4 0 115.656 5.656l-1.5 1.5"/>
              </svg>

              <%= link_to link[:label], link[:url], class: "hover:text-indigo-500 transition truncate" %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <%# ══════════════════════════════════════ %>
    <%# Coluna central — conteúdo principal      %>
    <%# ══════════════════════════════════════ %>
    <div class="space-y-6">

      <%# Showreels %>
      <div class="grid grid-cols-2 gap-6">
        <% @posts.each do |post| %>
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <div class="aspect-4/3 bg-linear-to-br from-indigo-100 to-slate-100 flex items-center justify-center">
              <% if post.attachments.attached? %>
                <%= image_tag post.attachments.first, alt: post.title, class: "w-full h-full object-cover" %>
              <% end %>
            </div>

            <p class="px-4 py-3 text-sm font-medium text-slate-700">
              <%= post.title %>
            </p>
          </div>
        <% end %>
      </div>

      <%# Experience %>
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h3 class="font-semibold text-slate-900 mb-5">Explore opções para seu perfil</h3>

        <ul class="space-y-3">
          <% @jobs.each do |job| %>
            <li class="bg-white border border-slate-200 rounded-xl px-6 py-5 flex flex-col gap-4 hover:border-slate-300 transition">

              <%# Topo: título + badge %>
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <h3 class="text-base font-semibold text-slate-900 leading-snug mb-1.5">
                    <%= job.title %>
                  </h3>
                  <p class="text-sm text-slate-500 leading-relaxed line-clamp-2">
                    <%= job.description %>
                  </p>
                </div>

                <%
                  badge = case job.status
                  when "open"   then { label: "Aberta",    cls: "bg-green-50 text-green-700 border-green-200" }
                  when "paused" then { label: "Pausada",   cls: "bg-yellow-50 text-yellow-700 border-yellow-200" }
                  when "closed" then { label: "Encerrada", cls: "bg-red-50 text-red-700 border-red-200" }
                  else               { label: job.status.humanize, cls: "bg-slate-100 text-slate-600 border-slate-200" }
                  end
                %>
                <span class="inline-flex items-center gap-1.5 flex-shrink-0 text-xs font-medium px-2.5 py-1 rounded-full border <%= badge[:cls] %>">
                  <span class="w-1.5 h-1.5 rounded-full bg-current opacity-70"></span>
                  <%= badge[:label] %>
                </span>
              </div>

              <%# Rodapé: orçamento + data %>
              <div class="flex items-center gap-5 pt-4 border-t border-slate-100">
                <span class="inline-flex items-center gap-1.5 text-sm text-slate-500">
                  <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                  </svg>
                  <span class="font-medium text-slate-800">
                    R$ <%= number_to_currency(job.budget, unit: "", separator: ",", delimiter: ".") %>
                  </span>
                </span>

                <span class="inline-flex items-center gap-1.5 text-sm text-slate-400">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
                  </svg>
                  <%= l(job.created_at.to_date, format: :long) %>
                </span>
              </div>

            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <%# ══════════════════════════════════════ %>
    <%# Coluna direita — stats + similar profile %>
    <%# ══════════════════════════════════════ %>
    <div class="space-y-6">

      <%# My stats %>
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h3 class="font-semibold text-slate-900 mb-4">My stats</h3>
        <div class="flex items-center gap-6 mb-4">
          <div>
            <p class="font-semibold text-slate-900"><%= @profile.stats[:views] %></p>
            <p class="text-xs text-slate-400">Views</p>
          </div>
          <div>
            <p class="font-semibold text-slate-900"><%= @profile.stats[:visitors] %></p>
            <p class="text-xs text-slate-400">Visitors</p>
          </div>
        </div>

        <%# Mini gráfico decorativo em SVG, sem libs externas %>
        <svg viewBox="0 0 200 60" class="w-full h-14" preserveAspectRatio="none">
          <polyline points="0,45 40,40 80,42 120,28 160,20 200,8"
                    fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" />
          <polygon points="0,45 40,40 80,42 120,28 160,20 200,8 200,60 0,60"
                   fill="#6366f1" opacity="0.08" />
        </svg>
        <div class="flex justify-between text-xs text-slate-400 mt-1">
          <span>Mon</span><span>Tue</span><span>Wed</span>
        </div>
      </div>

      <%# Similar profile %>
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h3 class="font-semibold text-slate-900 mb-4">Perfils similares</h3>
        <ul class="space-y-4">
          <% @similar_profiles.each do | profile | %>
            <%= link_to profile_path(profile.user.username), class: "group" do%>
              <li>
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-500 text-sm font-semibold shrink-0">
                    <%= profile.user.full_name.split.map(&:first).first(2).join.upcase%>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-slate-900 group-hover:text-indigo-600"><%= profile.user.full_name %></p>
                    <p class="text-xs text-slate-400"><%= profile.headline %></p>
                  </div>
                </div>
              </li>
            <% end %>
          <% end %>
        </ul>
      </div>
    </div>

  </div>
</div>