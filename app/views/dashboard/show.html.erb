<% content_for :title, "My Profile · FreelaHub" %>

<div class="max-w-7xl mx-auto px-6 py-8">
  <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr_280px] gap-6 items-start">

    <%# ══════════════════════════════════════ %>
    <%# Coluna esquerda — card de perfil         %>
    <%# ══════════════════════════════════════ %>
    <div class="bg-white rounded-2xl border border-slate-200 p-6">
      <div class="w-16 h-16 rounded-full bg-indigo-100 flex items-center justify-center mb-4 overflow-hidden">
        <span class="text-indigo-500 font-semibold text-lg"><%= @profile.initials %></span>
      </div>

      <h2 class="font-semibold text-slate-900"><%= @profile.name %></h2>
      <p class="text-sm text-slate-500 mt-0.5"><%= @profile.headline %></p>

      <div class="flex items-center gap-6 mt-5 pt-5 border-t border-slate-100">
        <div>
          <p class="font-semibold text-slate-900"><%= @profile.connections_count %></p>
          <p class="text-xs text-slate-400">Connections</p>
        </div>
        <div>
          <p class="font-semibold text-slate-900"><%= @profile.views_count %></p>
          <p class="text-xs text-slate-400">Views</p>
        </div>
      </div>

      <ul class="mt-5 pt-5 border-t border-slate-100 space-y-2.5">
        <% @profile.links.each do |link| %>
          <li class="flex items-center gap-2 text-sm text-slate-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 010 5.656l-3 3a4 4 0 11-5.656-5.656l1.5-1.5M10.172 13.828a4 4 0 010-5.656l3-3a4 4 0 115.656 5.656l-1.5 1.5"/>
            </svg>
            <%= link_to link[:label], link[:url], class: "hover:text-indigo-500 transition truncate" %>
          </li>
        <% end %>
      </ul>
    </div>

    <%# ══════════════════════════════════════ %>
    <%# Coluna central — conteúdo principal      %>
    <%# ══════════════════════════════════════ %>
    <div class="space-y-6">

      <%# Showreels %>
      <div class="grid grid-cols-2 gap-6">
        <% @profile.showreels.each do |reel| %>
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <div class="aspect-[4/3] bg-gradient-to-br from-indigo-100 to-slate-100 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"/>
              </svg>
            </div>
            <p class="px-4 py-3 text-sm font-medium text-slate-700"><%= reel[:title] %></p>
          </div>
        <% end %>
      </div>

      <%# Summary %>
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h3 class="font-semibold text-slate-900 mb-3">Summary</h3>
        <p class="text-sm text-slate-500 leading-relaxed"><%= @profile.summary %></p>
      </div>

      <%# Experience %>
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h3 class="font-semibold text-slate-900 mb-5">Experience</h3>

        <ul class="space-y-6">
          <% @profile.experiences.each do |exp| %>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-white text-xs font-semibold shrink-0 <%= exp[:badge_color] %>">
                <%= exp[:initials] %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-slate-900"><%= exp[:role] %></p>
                <p class="text-sm text-indigo-500"><%= exp[:company] %></p>
                <p class="text-xs text-slate-400 mt-0.5"><%= exp[:period] %></p>
                <p class="text-sm text-slate-500 mt-2 leading-relaxed"><%= exp[:description] %></p>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <%# ══════════════════════════════════════ %>
    <%# Coluna direita — stats + similar profile %>
    <%# ══════════════════════════════════════ %>
    <div class="space-y-6">

      <%# My stats %>
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h3 class="font-semibold text-slate-900 mb-4">My stats</h3>
        <div class="flex items-center gap-6 mb-4">
          <div>
            <p class="font-semibold text-slate-900"><%= @profile.stats[:views] %></p>
            <p class="text-xs text-slate-400">Views</p>
          </div>
          <div>
            <p class="font-semibold text-slate-900"><%= @profile.stats[:visitors] %></p>
            <p class="text-xs text-slate-400">Visitors</p>
          </div>
        </div>

        <%# Mini gráfico decorativo em SVG, sem libs externas %>
        <svg viewBox="0 0 200 60" class="w-full h-14" preserveAspectRatio="none">
          <polyline points="0,45 40,40 80,42 120,28 160,20 200,8"
                    fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" />
          <polygon points="0,45 40,40 80,42 120,28 160,20 200,8 200,60 0,60"
                   fill="#6366f1" opacity="0.08" />
        </svg>
        <div class="flex justify-between text-xs text-slate-400 mt-1">
          <span>Mon</span><span>Tue</span><span>Wed</span>
        </div>
      </div>

      <%# Similar profile %>
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h3 class="font-semibold text-slate-900 mb-4">Similar profile</h3>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-500 text-sm font-semibold shrink-0">
            <%= @profile.similar_profile[:initials] %>
          </div>
          <div>
            <p class="text-sm font-medium text-slate-900"><%= @profile.similar_profile[:name] %></p>
            <p class="text-xs text-slate-400"><%= @profile.similar_profile[:role] %></p>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>