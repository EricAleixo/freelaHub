<div id="<%= dom_id post %>" class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm w-85 sm:w-120 md:w-175 mx-auto">

  <%# Cabeçalho %>
  <div class="w-full flex items-center gap-3 px-4 pt-4">

    <%# Avatar com anel gradiente %>
    <div class="relative w-10 h-10 shrink-0">
      <div class="absolute inset-0 rounded-full bg-linear-to-br from-indigo-400 to-indigo-800"></div>
      <div class="absolute inset-0.5 rounded-full bg-indigo-50 flex items-center justify-center text-xs font-bold text-indigo-700 z-10">
        <%= post.user&.initials rescue "EA" %>
      </div>
    </div>

    <%# Nome + tempo %>
    <div class="flex-1 min-w-0">
      <p class="text-sm font-semibold text-gray-900 truncate leading-tight">
        <%= post.user&.full_name rescue "EA User" %>
      </p>
      <p class="text-xs text-gray-400 leading-tight mt-0.5">
        há <%= time_ago_in_words(post.created_at) %>
      </p>
    </div>

    <%# Menu de opções %>
    <div class="relative" data-controller="dropdown">
      <button
        data-action="click->dropdown#toggle"
        aria-label="Opções"
        class="p-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition bg-transparent border-0 cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 5h.01M12 12h.01M12 19h.01" />
        </svg>
      </button>

      <div
        data-dropdown-target="menu"
        class="hidden absolute right-0 mt-1 w-36 bg-white rounded-xl border border-gray-100 shadow-lg py-1 z-10"
      >
        <%= link_to "Editar", edit_post_path(post),
          class: "flex items-center gap-2 px-3 py-2 text-gray-700 hover:bg-gray-50 transition" %>
        <%= button_to "Excluir", post, method: :delete,
          class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-red-500 hover:bg-red-50 transition cursor-pointer bg-transparent border-0",
          data: { turbo_confirm: "Tem certeza?" } %>
      </div>
    </div>
  </div>

  <%# Título — antes da mídia %>
  <h2 class="text-lg px-4 pt-3 pb-2 text-[15px] font-semibold text-gray-900 leading-snug">
    <%= post.title %>
  </h2>

  <%# ── Chip de vaga vinculada ── %>
  <% if post.job.present? %>
    <div class="border border-indigo-100">

      <div class="flex items-start gap-3 p-4 transition-colors group">

        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white border border-indigo-100 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 text-indigo-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2">
            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>

        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2 flex-wrap">

            <h3 class="truncate text-lg font-semibold text-slate-900 transition-colors">
              <%= post.job.title %>
            </h3>

            <% if post.job.status == "open" %>
              <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-2 py-1 text-[11px] font-semibold text-emerald-700">
                <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
                Aberta
              </span>
            <% end %>

          </div>

        </div>

      </div>

      <div class="grid grid-cols-3 border-y border-indigo-100 bg-white">
        <div class="grid place-items-center border-r border-indigo-100 py-3">
          <span class="text-base font-semibold text-indigo-700">
          R$ <%= post.job.budget %>
          </span>
          <span class="text-xs text-slate-500">
            Orçamento
          </span>
        </div>

        <div class="grid place-items-center border-r border-indigo-100 py-3">
          <span class="text-base font-semibold text-indigo-700">
            <%= post.job.human_status %>
          </span>
          <span class="text-xs text-slate-500">
            Status
          </span>
        </div>

        <div class="grid place-items-center py-3">
          <span class="text-base font-semibold text-indigo-700">
            3 dias
          </span>
          <span class="text-xs text-slate-500">
            Propostas
          </span>
        </div>
      </div>

      <%= link_to job_path(post.job),
          class: "flex w-full items-center justify-center gap-2 border-t border-indigo-100 bg-white py-3 text-sm font-medium text-indigo-700 transition-colors hover:bg-indigo-50" do %>

        <svg xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2">
          <path stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.065 7-9.542 7S3.732 16.057 2.458 12z"/>
        </svg>

        <span>Ver vaga</span>

      <% end %>

    </div>
  <% end %>

  <%# Carrossel de mídia %>
  <% if post.attachments.attached? %>
    <section
      class="relative bg-[#0f0f1a] overflow-hidden"
      data-controller="post-carousel"
      data-post-carousel-total-value="<%= post.attachments.count %>"
    >
      <%# Track %>
      <div class="overflow-hidden">
        <div
          class="flex aspect-square transition-transform duration-300 ease-in-out"
          data-post-carousel-target="track"
        >
          <% post.attachments.each do |attachment| %>
            <div class="w-full shrink-0 bg-[#1a1a2e]">
              <% if attachment.image? %>
                <%= image_tag attachment,
                    class: "w-full h-full object-cover select-none",
                    draggable: false,
                    alt: post.title %>
              <% else %>
                <%= video_tag url_for(attachment),
                    controls: true,
                    playsinline: true,
                    class: "w-full h-full object-cover" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <% if post.attachments.count > 1 %>
        <%# Seta anterior %>
        <button
          type="button"
          data-action="click->post-carousel#prev"
          aria-label="Anterior"
          class="absolute left-2.5 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black/20 hover:bg-black/40 border border-white/20 text-white flex items-center justify-center backdrop-blur-sm transition z-10"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <%# Seta próximo %>
        <button
          type="button"
          data-action="click->post-carousel#next"
          aria-label="Próximo"
          class="absolute right-2.5 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black/20 hover:bg-black/40 border border-white/20 text-white flex items-center justify-center backdrop-blur-sm transition z-10"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        <%# Contador "1 / 3" %>
        <div
          data-post-carousel-target="counter"
          class="absolute top-2.5 right-2.5 bg-black/50 border border-white/10 text-indigo-100 text-[11px] font-semibold px-2.5 py-0.5 rounded-full tracking-wide z-10"
        ></div>

        <%# Dots %>
        <div
          data-post-carousel-target="dots"
          class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10"
        ></div>
      <% end %>
    </section>
  <% end %>

  <%# Descrição %>
  <% if post.description.present? %>
    <div class="px-4 pt-3">
      <p class="text-[18px] leading-relaxed text-gray-600 whitespace-pre-line">
        <%= post.description %>
      </p>
    </div>
  <% end %>

  <%# Ações %>
  <div class="flex items-center gap-1 px-2 py-3 mt-2 border-t border-gray-100">

    <button
      class="flex items-center gap-1.5 text-md font-medium text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-1.5 rounded-lg transition border-0 bg-transparent cursor-pointer"
      data-controller="like"
      data-action="click->like#toggle"
      aria-label="Curtir"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" data-like-target="icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
      Curtir
    </button>

    <button
      class="flex items-center gap-1.5 text-md font-medium text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-1.5 rounded-lg transition border-0 bg-transparent cursor-pointer"
      aria-label="Comentar"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      Comentar
    </button>

    <button
      class="flex items-center gap-1.5 text-md font-medium text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 px-3 py-1.5 rounded-lg transition border-0 bg-transparent cursor-pointer ml-auto"
      aria-label="Compartilhar"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
      </svg>
      Compartilhar
    </button>

  </div>

</div>