<% content_for :title, "Publicação" %>

<div class="max-w-6xl mx-auto my-7 px-4">

  <%# Notificação de sucesso %>
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-4 text-green-600 font-medium rounded-lg inline-block text-sm" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <div class="flex flex-col lg:flex-row lg:justify-center lg:items-start gap-6">

    <%# Post %>
    <%= render @post %>

    <%# Comentários (mock) — lado a lado com o post %>
    <div class="w-full lg:w-96 shrink-0">
      <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-4">

        <h3 class="text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Comentários
        </h3>

        <div class="flex flex-col gap-4 max-h-96 overflow-y-auto pr-1">

          <%# Comentário mock 1 %>
          <div class="flex items-start gap-2.5">
            <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-[11px] font-bold text-indigo-600 shrink-0">
              MS
            </div>
            <div class="min-w-0">
              <p class="text-xs font-semibold text-gray-900">Maria Silva</p>
              <p class="text-sm text-gray-600 leading-snug">Muito bom, exatamente o que eu procurava!</p>
              <p class="text-[11px] text-gray-400 mt-0.5">há 2 horas</p>
            </div>
          </div>

          <%# Comentário mock 2 %>
          <div class="flex items-start gap-2.5">
            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-[11px] font-bold text-emerald-600 shrink-0">
              JP
            </div>
            <div class="min-w-0">
              <p class="text-xs font-semibold text-gray-900">João Pereira</p>
              <p class="text-sm text-gray-600 leading-snug">Alguém sabe se ainda está disponível?</p>
              <p class="text-[11px] text-gray-400 mt-0.5">há 5 horas</p>
            </div>
          </div>

          <%# Comentário mock 3 %>
          <div class="flex items-start gap-2.5">
            <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center text-[11px] font-bold text-amber-600 shrink-0">
              EA
            </div>
            <div class="min-w-0">
              <p class="text-xs font-semibold text-gray-900">Equipe EA</p>
              <p class="text-sm text-gray-600 leading-snug">Obrigado por compartilhar com a comunidade!</p>
              <p class="text-[11px] text-gray-400 mt-0.5">há 1 dia</p>
            </div>
          </div>

        </div>

        <%# Campo de novo comentário (mock, sem funcionalidade ainda) %>
        <div class="flex items-center gap-2 mt-4 pt-4 border-t border-gray-100">
          <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-[11px] font-medium text-indigo-600 shrink-0">
            <%= current_user.initials rescue "EA" %>
          </div>
          <input type="text"
                 placeholder="Escreva um comentário..."
                 disabled
                 class="flex-1 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-400 outline-none cursor-not-allowed" />
        </div>

      </div>
    </div>

  </div>
</div>