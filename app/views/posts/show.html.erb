<% content_for :title, "Publicação" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-4 text-green-600 font-medium rounded-lg inline-block text-sm" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <%= render @post %>

  <div class="flex flex-wrap gap-2 mt-4">
    <%= link_to "Editar", edit_post_path(@post),
      class: "rounded-xl px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 transition" %>
    <%= link_to "Voltar", posts_path,
      class: "rounded-xl px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 transition" %>
    <%= button_to "Excluir", @post, method: :delete,
      class: "rounded-xl px-4 py-2 text-sm font-medium text-white bg-red-500 hover:bg-red-400 transition cursor-pointer",
      data: { turbo_confirm: "Tem certeza?" } %>
  </div>
</div>