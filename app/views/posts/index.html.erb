<% content_for :title, "Publicações" %>

<div class="max-w-7xl mx-auto my-7 pb-24" data-controller="posts-modal">

  <%# Notificação de sucesso %>
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-4 text-green-600 font-medium rounded-lg inline-block text-sm" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <%# Feed de publicações %>
  <div id="posts" class="flex flex-col gap-3">
    <% if @posts.any? %>
      <% @posts.order(created_at: :desc).each do |post| %>
        <%= render post %>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center py-24 text-gray-900" id="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-3 text-gray-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536M9 13l6-6m-6 6l-1.5 4.5 4.5-1.5L18 9.5a2.121 2.121 0 00-3-3L9 13z" />
        </svg>
        <p class="text-sm font-medium">Nenhuma publicação ainda.</p>
        <p class="text-xs mt-1">Toque no + para começar.</p>
      </div>
    <% end %>
  </div>

  <%# Botão flutuante (FAB) %>
  <button
    data-action="click->posts-modal#open"
    aria-label="Nova publicação"
    class="fixed bottom-6 right-6 z-30 rounded-full bg-indigo-600 hover:bg-indigo-500 active:scale-95 text-white flex items-center justify-center transition-all duration-150 cursor-pointer border-0"
    style="width: 52px; height: 52px;"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
    </svg>
  </button>

  <%# Modal — bottom sheet %>
  <div
    data-posts-modal-target="overlay"
    class="fixed inset-0 z-40 hidden"
    aria-modal="true"
    role="dialog"
    aria-label="Nova publicação"
  >
    <%# Backdrop %>
    <div
      data-action="click->posts-modal#close"
      class="absolute inset-0 bg-black/40"
    ></div>

    <%# Sheet %>
    <div
      data-posts-modal-target="sheet"
      class="absolute bottom-0 left-0 right-0
            bg-white rounded-t-2xl border-t border-gray-200
            translate-y-full transition-all duration-300"
    >
      <%# Handle %>
      <div class="flex justify-center pt-3 pb-1">
        <div class="w-9 h-1 rounded-full bg-gray-200"></div>
      </div>

      <div class="px-5 pb-8 pt-4">
        <%# Cabeçalho do autor %>
        <div class="flex items-center gap-3 mb-5">
          <div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center text-xs font-medium text-indigo-600 shrink-0">
            <%= current_user.initials rescue "EA" %>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-900"><%= current_user.name rescue "EA User" %></p>
            <p class="text-xs text-gray-400">Publicação pública</p>
          </div>
        </div>

        <%# Formulário %>
        <%= form_with(model: Post.new, data: { action: "submit->posts-modal#submit" }) do |form| %>

          <div class="mb-3">
            <%= form.text_field :title,
              placeholder: "Título",
              data: { posts_modal_target: "titleInput" },
              class: "block w-full rounded-lg border border-gray-300 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 outline-none transition" %>
          </div>

          <div data-controller="media-picker" class="mb-4">
            <div>
              <%= form.file_field :attachments,
                  multiple: true,
                  include_hidden: false,
                  class: "hidden",
                  data: {
                    media_picker_target: "input",
                    action: "change->media-picker#add"
                  } %>
              <div data-media-picker-target="grid" class="grid grid-cols-4 gap-3"></div>
            </div>
          </div>

          <div class="my-3">
            <%= form.text_area :description,
              rows: 3,
              placeholder: "O que você quer compartilhar?",
              data: { posts_modal_target: "descInput" },
              class: "block w-full rounded-lg border border-gray-300 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 outline-none transition resize-none" %>
          </div>

          <%# ── Vincular vaga (opcional) ── %>
          <% user_jobs = current_user.jobs.order(created_at: :desc) rescue [] %>
          <% if user_jobs.any? %>
            <div data-controller="job-link" class="mb-5">

              <%# Campo hidden que vai no form %>
              <%= form.hidden_field :job_id, data: { job_link_target: "hiddenInput" } %>

              <%# Estado idle: botão dashed %>
              <div data-job-link-target="idleState">
                <button
                  type="button"
                  data-action="click->job-link#open"
                  class="group w-full flex items-center gap-3 px-3 py-2.5 rounded-xl border border-dashed border-gray-300 hover:border-indigo-400 hover:bg-indigo-50/50 transition-all duration-150 cursor-pointer bg-transparent text-left"
                >
                  <span class="w-7 h-7 rounded-lg bg-gray-100 group-hover:bg-indigo-100 flex items-center justify-center shrink-0 transition-colors duration-150">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 group-hover:text-indigo-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </span>
                  <span class="text-sm text-gray-500 group-hover:text-indigo-600 transition-colors">Vincular uma vaga a este post</span>
                </button>
              </div>

              <%# Estado picker: lista customizada %>
              <div data-job-link-target="pickerState" class="hidden">
                <div class="rounded-xl border border-indigo-200 bg-white overflow-hidden shadow-sm">

                  <%# Cabeçalho do picker %>
                  <div class="flex items-center justify-between px-3.5 py-2.5 border-b border-gray-100 bg-gray-50/80">
                    <div class="flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                      <span class="text-xs font-semibold text-gray-500 tracking-wide">Suas vagas</span>
                    </div>
                    <button
                      type="button"
                      data-action="click->job-link#cancel"
                      class="p-1 rounded-md text-gray-400 hover:text-gray-600 hover:bg-gray-200 transition cursor-pointer border-0 bg-transparent"
                      aria-label="Fechar"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                    </button>
                  </div>

                  <%# Lista de vagas %>
                  <ul class="divide-y divide-gray-50 max-h-48 overflow-y-auto" role="listbox" aria-label="Vagas disponíveis">
                    <% user_jobs.each do |job| %>
                      <li
                        role="option"
                        data-action="click->job-link#select"
                        data-job-id="<%= job.id %>"
                        data-job-title="<%= job.title %>"
                        data-job-status="<%= job.status %>"
                        class="flex items-center gap-3 px-3.5 py-3 cursor-pointer hover:bg-indigo-50 transition-colors group select-none"
                      >
                        <%# Ícone de status colorido %>
                        <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 transition-colors
                          <%= job.open? ? 'bg-emerald-50 group-hover:bg-emerald-100' : 'bg-gray-100 group-hover:bg-gray-200' %>">
                          <% if job.open? %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                          <% else %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                          <% end %>
                        </span>

                        <%# Título + badge de status %>
                        <div class="flex-1 min-w-0">
                          <p class="text-sm font-medium text-gray-800 group-hover:text-indigo-700 transition-colors truncate leading-tight">
                            <%= job.title %>
                          </p>
                          <p class="text-xs text-gray-400 mt-0.5">
                            <% if job.budget.present? %>
                              $<%= number_with_delimiter(job.budget.to_i) %> &middot;
                            <% end %>
                            <% status_label = { "draft" => "Rascunho", "open" => "Aberta", "paused" => "Pausada", "closed" => "Encerrada" } %>
                            <%= status_label[job.status] || job.status.titleize %>
                          </p>
                        </div>

                        <%# Badge de status %>
                        <% if job.open? %>
                          <span class="inline-flex items-center gap-1 text-[10px] font-semibold text-emerald-600 bg-emerald-50 border border-emerald-100 rounded-md px-1.5 py-0.5 leading-none shrink-0">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
                            Aberta
                          </span>
                        <% elsif job.draft? %>
                          <span class="inline-flex items-center text-[10px] font-semibold text-gray-500 bg-gray-100 border border-gray-200 rounded-md px-1.5 py-0.5 leading-none shrink-0">
                            Rascunho
                          </span>
                        <% elsif job.paused? %>
                          <span class="inline-flex items-center text-[10px] font-semibold text-amber-600 bg-amber-50 border border-amber-100 rounded-md px-1.5 py-0.5 leading-none shrink-0">
                            Pausada
                          </span>
                        <% elsif job.closed? %>
                          <span class="inline-flex items-center text-[10px] font-semibold text-red-500 bg-red-50 border border-red-100 rounded-md px-1.5 py-0.5 leading-none shrink-0">
                            Encerrada
                          </span>
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                </div>
              </div>

              <%# Estado selected: chip com nome da vaga %>
              <div data-job-link-target="selectedState" class="hidden">
                <div class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl bg-indigo-50 border border-indigo-200">
                  <span class="w-7 h-7 rounded-lg bg-indigo-100 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </span>
                  <div class="flex-1 min-w-0">
                    <p class="text-xs text-indigo-400 leading-none mb-0.5">Vaga vinculada</p>
                    <p data-job-link-target="selectedLabel" class="text-sm font-semibold text-indigo-700 truncate leading-tight"></p>
                  </div>
                  <button
                    type="button"
                    data-action="click->job-link#clear"
                    aria-label="Remover vaga"
                    class="p-1.5 rounded-lg text-indigo-300 hover:text-indigo-600 hover:bg-indigo-100 transition cursor-pointer border-0 bg-transparent shrink-0"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </button>
                </div>
              </div>

            </div>
          <% end %>

          <p data-posts-modal-target="errorMsg" class="hidden text-xs text-red-500 mb-3"></p>

          <div class="flex justify-end gap-2">
            <button
              type="button"
              data-action="click->posts-modal#close"
              class="rounded-lg px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 transition cursor-pointer border-0"
            >
              Cancelar
            </button>
            <%= form.submit "Publicar",
              class: "rounded-lg px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-500 transition cursor-pointer border-0 font-bold" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

</div>