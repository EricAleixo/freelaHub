<% content_for :title, "Editar publicação" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-2xl text-gray-900 mb-6">Editar publicação</h1>
  <%= render "form", post: @post %>
  <div class="flex gap-3 mt-3">
    <%= link_to "Ver publicação", @post, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <%= link_to "Voltar", posts_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
</div>