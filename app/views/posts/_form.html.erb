<%= form_with(model: post, class: "space-y-4") do |form| %>

  <% if post.errors.any? %>
    <div class="bg-red-50 text-red-600 px-4 py-3 rounded-xl text-sm">
      <p class="font-medium mb-1"><%= pluralize(post.errors.count, "erro impediu") %> salvar esta publicação:</p>
      <ul class="list-disc ml-4 space-y-0.5">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, "Título", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title,
      placeholder: "Dê um título à sua publicação",
      class: [
        "block w-full rounded-xl border px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 outline-none transition focus:ring-2 focus:ring-offset-0",
        post.errors[:title].none? ? "border-gray-300 focus:border-indigo-500 focus:ring-indigo-200" : "border-red-400 focus:ring-red-200"
      ] %>
  </div>

  <div>
    <%= form.label :description, "Descrição", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :description,
      rows: 4,
      placeholder: "O que você quer compartilhar?",
      class: [
        "block w-full rounded-xl border px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 outline-none transition focus:ring-2 focus:ring-offset-0 resize-none",
        post.errors[:description].none? ? "border-gray-300 focus:border-indigo-500 focus:ring-indigo-200" : "border-red-400 focus:ring-red-200"
      ] %>
  </div>

  <div class="flex justify-end">
    <%= form.submit class: "rounded-xl px-5 py-2.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-500 active:scale-95 transition cursor-pointer border-0" %>
  </div>

<% end %>