<div id="<%= dom_id proposal %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Profile:</strong>
    <%= proposal.profile_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Job:</strong>
    <%= proposal.job_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Message:</strong>
    <%= proposal.message %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Value:</strong>
    <%= proposal.value %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= proposal.status %>
  </div>
</div>
