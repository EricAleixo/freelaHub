<%= form_with(model: profile_skill, class: "contents") do |form| %>
  <% if profile_skill.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(profile_skill.errors.count, "error") %> prohibited this profile_skill from being saved:</h2>

      <ul class="list-disc ml-6">
        <% profile_skill.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :profile_id %>
    <%= form.text_field :profile_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": profile_skill.errors[:profile_id].none?, "border-red-400 focus:outline-red-600": profile_skill.errors[:profile_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :skill_id %>
    <%= form.text_field :skill_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": profile_skill.errors[:skill_id].none?, "border-red-400 focus:outline-red-600": profile_skill.errors[:skill_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :level %>
    <%= form.text_field :level, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": profile_skill.errors[:level].none?, "border-red-400 focus:outline-red-600": profile_skill.errors[:level].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
