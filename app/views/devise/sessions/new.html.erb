<div class="min-h-screen flex font-sans">

  <%# ── Painel esquerdo ── %>
  <div class="hidden lg:flex lg:w-[46%] xl:w-[48%] shrink-0 relative flex-col justify-between p-12 overflow-hidden"
       style="background: linear-gradient(160deg, #0f1535 0%, #1a2260 55%, #0f1535 100%);">

    <%# Textura sutil de pontos %>
    <div class="absolute inset-0 opacity-[0.07]"
         style="background-image: radial-gradient(#a5b4fc 1px, transparent 1px); background-size: 28px 28px;"></div>

    <%# Logo %>
    <div class="relative">
      <%= image_tag "logo.png", class: "w-20" %>
    </div>

    <%# Headline central %>
    <div class="relative z-10">
      <h2 class="text-4xl xl:text-5xl font-bold text-white leading-tight tracking-tight">
        Conectando talentos<br>a oportunidades<br>reais.
      </h2>
      <p class="mt-5 text-slate-400 text-base leading-relaxed max-w-xs">
        A plataforma SaaS definitiva para acadêmicos e profissionais que buscam excelência em cada contrato.
      </p>
    </div>

    <%# Rodapé com avatares %>
    <div class="relative z-10 flex items-center gap-4">
      <%# Grupo de avatares em CSS %>
      <div class="flex -space-x-2">
        <% [["#6366f1","A"], ["#8b5cf6","B"], ["#a78bfa","C"]].each do |color, letter| %>
          <div class="w-9 h-9 rounded-full border-2 border-[#1a2260] flex items-center justify-center text-white text-xs font-semibold"
               style="background-color: <%= color %>;">
            <%= letter %>
          </div>
        <% end %>
      </div>
      <p class="text-slate-300 text-sm font-medium">Mais de 10k+ talentos ativos</p>
    </div>
  </div>

  <%# ── Painel direito (formulário) ── %>
  <div class="flex-1 flex items-center justify-center bg-white px-8 py-12">
    <div class="w-full max-w-md">

      <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Bem-vindo de volta</h1>
      <p class="text-slate-500 text-sm mt-2 mb-8">Insira suas credenciais para acessar sua conta.</p>

      <%# Botão Google %>
      <%= link_to "#",
            class: "flex items-center justify-center gap-3 w-full py-3 border border-slate-200 rounded-xl text-slate-700 text-sm font-medium hover:bg-slate-50 transition mb-6" do %>
        <%# Ícone Google em SVG inline %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue com Google
      <% end %>

      <%# Divisor %>
      <div class="flex items-center gap-3 mb-6 text-slate-400 text-xs">
        <span class="flex-1 h-px bg-slate-200"></span>
        ou use seu e-mail
        <span class="flex-1 h-px bg-slate-200"></span>
      </div>

      <%# Formulário Devise %>
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

        <%# E-mail %>
        <div class="mb-4">
          <%= f.label :email, "E-mail",
                class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "exemplo@freelahub.com",
                class: "w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-900 placeholder-slate-400 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-indigo-400 transition" %>
        </div>

        <%# Senha %>
        <div class="mb-5">
          <div class="flex justify-between items-center mb-1.5">
            <%= f.label :password, "Senha",
                  class: "text-sm font-medium text-slate-700" %>
            <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
              <%= link_to "Esqueceu a senha?", new_password_path(resource_name),
                    class: "text-xs text-indigo-500 hover:text-indigo-700 font-medium transition" %>
            <% end %>
          </div>
          <div class="relative">
            <%= f.password_field :password,
                  autocomplete: "current-password",
                  class: "w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-indigo-400 transition pr-11" %>
            <%# Ícone de olho (decorativo) %>
            <span class="absolute inset-y-0 right-3 flex items-center text-slate-400 pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </span>
          </div>
        </div>

        <%# Lembrar de mim %>
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2 mb-6">
            <%= f.check_box :remember_me,
                  class: "w-4 h-4 rounded border-slate-300 text-indigo-500 focus:ring-indigo-400 cursor-pointer" %>
            <%= f.label :remember_me, "Lembrar de mim",
                  class: "text-sm text-slate-600 cursor-pointer" %>
          </div>
        <% end %>

        <%# Submit %>
        <%= f.submit "Entrar",
              class: "w-full py-3 bg-indigo-500 hover:bg-indigo-600 active:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition cursor-pointer shadow-sm shadow-indigo-200" %>

      <% end %>

      <%# Criar conta %>
      <p class="text-center text-sm text-slate-500 mt-6">
        Não tem uma conta?
        <%= link_to "Criar conta", new_user_registration_path,
              class: "text-indigo-500 font-semibold hover:text-indigo-700 transition" %>
      </p>

      <%# Selo SSL %>
      <p class="flex items-center justify-center gap-1.5 mt-8 text-slate-400 text-xs">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
        </svg>
        Conexão segura SSL de 256 bits
      </p>

    </div>
  </div>
</div>