<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "FreelaHub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-100 font-sans text-slate-900">

    <%# ════════════════════════════════════════════════ %>
    <%# Header global — aparece em toda página logada     %>
    <%# ════════════════════════════════════════════════ %>
    <header class="bg-white border-b border-slate-200 sticky top-0 z-30">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center gap-6">

        <%# Logo %>
        <%= link_to root_path, class: "flex items-center gap-2 shrink-0" do %>
          <div class="w-8 h-8 rounded-lg bg-indigo-500 flex items-center justify-center">
            <span class="text-white font-bold text-sm leading-none">F</span>
          </div>
          <span class="text-slate-900 font-bold text-base tracking-tight hidden sm:inline">FreelaHub</span>
        <% end %>

        <%# Busca %>
        <div class="flex-1 max-w-md">
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"/>
            </svg>
            <input type="text"
                   placeholder="Ache o que você procura..."
                   class="w-full pl-9 pr-4 py-2 bg-slate-100 border border-transparent rounded-lg text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-200 focus:bg-white focus:border-indigo-300 transition">
          </div>
        </div>

        <%# Ícones + avatar %>
        <div class="flex items-center gap-4 ml-auto shrink-0">

          <button class="text-slate-500 hover:text-slate-700 transition" aria-label="Messages">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </button>

          <% unread_notifications = current_user.notifications.unread.count %>

          <%= link_to notifications_path,
                class: "relative text-slate-500 hover:text-slate-700 transition" do %>

            <% if unread_notifications.positive? %>
              <span class="absolute -top-2 -right-2 min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center leading-none">
                <%= unread_notifications > 99 ? "99+" : unread_notifications %>
              </span>
            <% end %>

            <svg xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.8">
              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>

          <% end %>

          <%= link_to profile_path(current_user.username),
                title: "Ver perfil",
                class: "block w-8 h-8 rounded-full bg-indigo-100 border border-slate-200 overflow-hidden shrink-0 hover:ring-2 hover:ring-indigo-200 transition" do %>
            <div class="w-full h-full flex items-center justify-center text-indigo-500 text-xs font-semibold">
              <%= current_user&.profile&.initials || current_user&.email&.first&.upcase || "U" %>
            </div>
          <% end %>
        </div>
      </div>
    </header>

    <%# ════════════════════════════════════════════════ %>
    <%# Conteúdo de cada página                            %>
    <%# ════════════════════════════════════════════════ %>
    <main>
      <%= render "shared/top_nav", active: :details %>
      <% if notice %>
        <div
          data-flash
          class="fixed top-5 left-1/2 -translate-x-1/2 -translate-y-full opacity-0 transition-all duration-500 z-50 w-full max-w-6xl px-6"
        >
          <div class="py-2 text-sm text-emerald-700 bg-emerald-200 border border-emerald-400 rounded flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>

            <p><%= notice %></p>
          </div>
        </div>
    <% end %>

    <% if alert %>
        <div
          data-flash
          class="fixed top-5 left-1/2 -translate-x-1/2 -translate-y-full opacity-0 transition-all duration-500 z-50 w-full max-w-6xl px-6"
        >
          <div class="py-2 text-sm text-red-700 bg-red-200 border border-red-400 rounded flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>

            <p><%= alert %></p>
          </div>
        </div>
    <% end %>

      <%= yield %>
    </main>

  </body>
</html>