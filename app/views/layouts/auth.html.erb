<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "FreelaHub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-100 font-sans text-slate-900">
    <%# ════════════════════════════════════════════════ %>
    <%# Conteúdo de cada página                            %>
    <%# ════════════════════════════════════════════════ %>
    <main>
      <% if notice %>
        <div
          data-controller="flash"
          class="fixed top-5 left-1/2 -translate-x-1/2 -translate-y-full opacity-0 transition-all duration-500 z-50 w-full max-w-6xl px-6"
        >
          <div class="py-2 text-sm text-emerald-700 bg-emerald-200 border border-emerald-400 rounded flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>

            <p><%= notice %></p>
          </div>
        </div>
      <% end %>
      <% if alert %>
        <div
          data-controller="flash"
          class="fixed top-5 left-1/2 -translate-x-1/2 -translate-y-full opacity-0 transition-all duration-500 z-50 w-full max-w-6xl px-6"
        >
          <div class="py-2 px-2 text-sm text-red-700 bg-red-200 border border-red-400 rounded flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>

            <p><%= alert %></p>
          </div>
        </div>
      <% end %>

      <%= yield %>
    </main>

  </body>
</html>