<% content_for :title, "Notificações · FreelaHub" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-900">Notificações</h1>
      <p class="mt-2 text-slate-500">Acompanhe as atualizações das suas vagas e propostas.</p>
    </div>
    <% if @notifications.any? %>
      <%= button_to "Limpar tudo",
            notifications_path,
            method: :delete,
            params: { clear_all: true },
            class: "text-xs font-medium text-slate-400 hover:text-red-500 transition" %>
    <% end %>
  </div>

  <% if @notifications.any? %>
    <div class="space-y-3">
      <% @notifications.each do |notification| %>
        <% proposal = notification.notifiable if notification.notifiable_type == "Proposal" %>
        <% sender = proposal&.profile&.user %>

        <div class="rounded-2xl border bg-white overflow-hidden transition hover:border-indigo-200
          <%= notification.read? ? 'border-slate-200' : 'border-indigo-300' %>">

          <%# Faixa superior colorida para não lidas %>
          <% unless notification.read? %>
            <div class="h-1 w-full bg-indigo-500 rounded-t-2xl"></div>
          <% end %>

          <div class="p-5">
            <div class="flex items-start gap-4">

              <%# Avatar do remetente %>
              <div class="shrink-0">
                <% if sender %>
                  <div class="relative">
                    <div class="h-11 w-11 rounded-full bg-indigo-100 border-2 border-white ring-1 ring-indigo-200 flex items-center justify-center text-sm font-semibold text-indigo-600">
                      <%= sender.full_name.split.first(2).map { |n| n[0] }.join.upcase %>
                    </div>
                    <%# Ícone de tipo no canto do avatar %>
                    <div class="absolute -bottom-1 -right-1 h-5 w-5 rounded-full flex items-center justify-center border-2 border-white
                      <%= notification.new_proposal? ? 'bg-indigo-500' : notification.proposal_accepted? ? 'bg-emerald-500' : 'bg-red-400' %>">
                      <% if notification.new_proposal? %>
                        <svg class="h-2.5 w-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m6 9h.008v.008H14.25V15z"/>
                        </svg>
                      <% elsif notification.proposal_accepted? %>
                        <svg class="h-2.5 w-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                        </svg>
                      <% else %>
                        <svg class="h-2.5 w-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                      <% end %>
                    </div>
                  </div>
                <% else %>
                  <div class="h-11 w-11 rounded-full bg-slate-100 flex items-center justify-center">
                    <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/>
                    </svg>
                  </div>
                <% end %>
              </div>

              <%# Conteúdo principal %>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">

                    <%# Nome + badge nova %>
                    <div class="flex items-center gap-2 flex-wrap">
                      <% if sender %>
                        <span class="text-sm font-semibold text-slate-900"><%= sender.full_name %></span>
                        <% if sender.username.present? %>
                          <span class="text-xs text-slate-400">@<%= sender.username %></span>
                        <% end %>
                      <% end %>
                      <% unless notification.read? %>
                        <span class="inline-flex items-center text-[10px] font-semibold text-indigo-600 bg-indigo-50 border border-indigo-100 rounded-full px-2 py-0.5 uppercase tracking-wide">Nova</span>
                      <% end %>
                    </div>

                    <%# Curso + instituição %>
                    <% profile = proposal&.profile %>
                    <% if profile&.course.present? || profile&.institution.present? %>
                      <p class="text-xs text-slate-400 mt-0.5">
                        <%= [profile.course, profile.institution].compact.join(" · ") %>
                      </p>
                    <% end %>

                    <%# Mensagem %>
                    <p class="text-sm text-slate-600 mt-2 leading-relaxed"><%= notification.message %></p>

                    <%# Preview da mensagem da proposta %>
                    <% if proposal&.message.present? %>
                      <p class="mt-2 text-xs text-slate-400 italic line-clamp-2 border-l-2 border-slate-200 pl-2">
                        "<%= proposal.message %>"
                      </p>
                    <% end %>

                    <%# Valor da proposta %>
                    <% if proposal&.value.present? %>
                      <div class="mt-3 inline-flex items-center gap-1.5 bg-emerald-50 border border-emerald-100 rounded-lg px-3 py-1.5">
                        <svg class="h-3.5 w-3.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33"/>
                        </svg>
                        <span class="text-xs font-semibold text-emerald-700"><%= number_to_currency(proposal.value) %></span>
                      </div>
                    <% end %>

                    <p class="mt-2 text-xs text-slate-400"><%= time_ago_in_words(notification.created_at) %> atrás</p>
                  </div>

                  <%# Botão remover %>
                  <%= button_to notification_path(notification),
                        method: :delete,
                        class: "shrink-0 flex h-7 w-7 items-center justify-center rounded-lg text-slate-300 hover:text-red-400 hover:bg-red-50 transition",
                        title: "Remover" do %>
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  <% end %>
                </div>

                <%# Botão ver proposta %>
                <% if proposal.present? %>
                  <div class="mt-4">
                    <%= link_to job_path(proposal.job),
                          class: "inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-4 py-2 text-xs font-semibold text-white hover:bg-indigo-700 transition" do %>
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.065 7-9.542 7S3.732 16.057 2.458 12z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      Ver proposta
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <div class="rounded-2xl border border-dashed border-slate-300 bg-white py-20">
      <div class="mx-auto max-w-sm text-center">
        <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-slate-900">Tudo em dia</h2>
        <p class="mt-2 text-sm text-slate-500 leading-relaxed">
          Nenhuma notificação por enquanto.<br>
          Quando houver novidades, elas aparecerão aqui.
        </p>
      </div>
    </div>
  <% end %>

</div>