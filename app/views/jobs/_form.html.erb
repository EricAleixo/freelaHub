<%#
  Form de Job, usado em new e edit.
  Sempre escopado ao usuário logado — o controller já garante que
  @job pertence a current_user (current_user.jobs.new / .find).
%>
<%= form_with(model: job, class: "space-y-6") do |form| %>

  <%# ── Erros ── %>
  <% if job.errors.any? %>
    <div id="error_explanation" class="bg-red-50 border border-red-100 text-red-600 px-4 py-3 text-sm font-medium rounded-xl">
      <h2 class="font-semibold mb-1"><%= pluralize(job.errors.count, "erro") %> encontrado<%= job.errors.count > 1 ? "s" : "" %>:</h2>
      <ul class="list-disc ml-5 space-y-0.5">
        <% job.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Título ── %>
  <div>
    <%= form.label :title, "Título do trabalho", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.text_field :title,
      placeholder: "ex: Desenvolvedor React Sênior",
      autofocus: true,
      class: field_classes(job, :title) %>
  </div>

  <%# ── Descrição ── %>
  <div>
    <%= form.label :description, "Descrição", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.text_area :description, rows: 6,
      placeholder: "Descreva as responsabilidades, requisitos e o que é esperado nessa função…",
      class: field_classes(job, :description) %>
    <p class="text-xs text-slate-400 mt-1.5">Seja específico — vagas claras recebem melhores propostas.</p>
  </div>

  <%# ── Budget + Status, lado a lado ── %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <%= form.label :budget, "Orçamento", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <div class="relative">
        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-sm">$</span>
        <%= form.number_field :budget,
          step: 0.01,
          min: 0,
          placeholder: "0.00",
          class: field_classes(job, :budget, with_icon: true) %>
      </div>
    </div>

    <div>
      <%= form.label :status, "Status", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= form.select :status,
        Job.statuses.keys.map { |key| [key.titleize, key] },
        {},
        class: field_classes(job, :status) + " cursor-pointer" %>
    </div>
  </div>

  <%# ── Info de status ── %>
  <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex items-start gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
    </svg>
    <p class="text-sm text-slate-500 leading-relaxed">
      <span class="font-medium text-slate-700">Draft</span> — visível apenas para você. &nbsp;
      <span class="font-medium text-slate-700">Open</span> — aceita propostas. &nbsp;
      <span class="font-medium text-slate-700">Paused</span> — oculto temporariamente. &nbsp;
      <span class="font-medium text-slate-700">Closed</span> — não aceita mais propostas.
    </p>
  </div>

  <%# ── Ações + opção de post ── %>
  <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 pt-2 border-t border-slate-100">

    <%# Esquerda: link para criar post (só aparece se o job já foi salvo) %>
    <% if job.persisted? %>
      <%= link_to new_post_path(job_id: job.id),
        class: "inline-flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-700 transition group" do %>
        <span class="w-7 h-7 rounded-full bg-indigo-50 group-hover:bg-indigo-100 flex items-center justify-center transition shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 13l6-6m-6 6l-1.5 4.5 4.5-1.5L18 9.5a2.121 2.121 0 00-3-3L9 13z" />
          </svg>
        </span>
        Criar post sobre este trabalho
      <% end %>
    <% else %>
      <%# Placeholder para jobs ainda não salvos %>
      <p class="text-xs text-slate-400 italic">Salve o trabalho para criar um post.</p>
    <% end %>

    <%# Direita: cancelar + salvar %>
    <div class="flex items-center justify-end gap-3">
      <%= link_to "Cancelar", jobs_path,
        class: "px-5 py-2.5 text-sm font-medium text-slate-600 hover:text-slate-900 transition" %>
      <%= form.submit job.new_record? ? "Publicar vaga" : "Salvar alterações",
        class: "px-5 py-2.5 bg-indigo-500 hover:bg-indigo-600 active:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition cursor-pointer shadow-sm shadow-indigo-200" %>
    </div>
  </div>

<% end %>