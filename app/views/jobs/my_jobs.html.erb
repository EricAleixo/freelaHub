<% content_for :title, "Minhas vagas · FreelaHub" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <% if notice.present? %>
    <div id="notice" class="mb-6 flex items-center gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <%= notice %>
    </div>
  <% end %>

  <%# Cabeçalho %>
  <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-900">Minhas vagas</h1>
      <p class="mt-2 text-slate-500">Vagas que você criou e trabalhos que se candidatou.</p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to jobs_path,
            class: "inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 transition hover:border-slate-300 hover:text-slate-900" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.065 7-9.542 7S3.732 16.057 2.458 12z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Ver todas as vagas
      <% end %>
      <%= link_to new_job_path,
            class: "inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-indigo-700" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
        </svg>
        Publicar vaga
      <% end %>
    </div>
  </div>

  <%# Stats %>
  <div class="grid gap-4 sm:grid-cols-3 mb-10">
    <div class="rounded-2xl border border-slate-200 bg-white p-5">
      <p class="text-xs font-medium text-slate-400 uppercase tracking-wide">Vagas criadas</p>
      <p class="mt-2 text-3xl font-bold text-indigo-600"><%= @my_jobs.count %></p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5">
      <p class="text-xs font-medium text-slate-400 uppercase tracking-wide">Candidaturas</p>
      <p class="mt-2 text-3xl font-bold text-slate-900"><%= @my_proposals.count %></p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5">
      <p class="text-xs font-medium text-slate-400 uppercase tracking-wide">Propostas aceitas</p>
      <p class="mt-2 text-3xl font-bold text-slate-900"><%= @my_proposals.count { |p| p.status == "accepted" } %></p>
    </div>
  </div>

  <%# ── Seção 1: Vagas que criei ── %>
  <div class="mb-10">
    <h2 class="text-lg font-semibold text-slate-900 mb-4">Vagas que criei</h2>

    <% if @my_jobs.any? %>
      <div class="space-y-4">
        <% @my_jobs.each do |job| %>
          <div class="rounded-2xl border border-slate-200 bg-white transition hover:border-indigo-200 overflow-hidden">
            <div class="p-5 sm:p-6">
              <div class="flex items-start justify-between gap-4">
                <div class="flex gap-3.5 items-start">
                  <div class="shrink-0 flex h-12 w-12 items-center justify-center rounded-xl border border-indigo-100 bg-indigo-50">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                  </div>
                  <div>
                    <%= link_to job, class: "text-base font-semibold text-slate-900 hover:text-indigo-600 transition leading-snug" do %>
                      <%= job.title %>
                    <% end %>
                    <div class="mt-1.5 flex items-center gap-2">
                      <span class="text-xs text-slate-400">Publicada há <%= time_ago_in_words(job.created_at) %></span>
                    </div>
                    <div class="mt-2.5">
                      <span class="<%= job.status_badge_class %>"><%= job.human_status %></span>
                    </div>
                  </div>
                </div>

                <div class="flex items-center gap-1.5 shrink-0">
                  <%= link_to job,
                        class: "flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 hover:text-slate-700 transition",
                        title: "Ver" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.065 7-9.542 7S3.732 16.057 2.458 12z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                  <% end %>
                  <%= link_to edit_job_path(job),
                        class: "flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 hover:text-slate-700 transition",
                        title: "Editar" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/>
                    </svg>
                  <% end %>
                  <%= button_to job,
                        method: :delete,
                        form: { data: { turbo_confirm: "Excluir \"#{job.title}\"?" } },
                        class: "flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:bg-red-50 hover:border-red-200 hover:text-red-500 transition",
                        title: "Excluir" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
                    </svg>
                  <% end %>
                </div>
              </div>

              <% if job.description.present? %>
                <p class="mt-4 text-sm text-slate-500 leading-relaxed line-clamp-2"><%= job.description %></p>
              <% end %>
            </div>

            <div class="grid grid-cols-3 divide-x divide-slate-100 border-t border-slate-100 bg-slate-50/60">
              <div class="py-3.5 text-center">
                <p class="text-sm font-semibold text-indigo-600"><%= job.budget.present? ? number_to_currency(job.budget) : "—" %></p>
                <p class="mt-0.5 text-xs text-slate-400">Orçamento</p>
              </div>
              <div class="py-3.5 text-center">
                <p class="text-sm font-semibold text-indigo-600"><%= job.proposals.count %></p>
                <p class="mt-0.5 text-xs text-slate-400">Propostas</p>
              </div>
              <div class="py-3.5 text-center">
                <p class="text-sm font-semibold text-indigo-600"><%= l(job.created_at.to_date) %></p>
                <p class="mt-0.5 text-xs text-slate-400">Publicada em</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>

    <% else %>
      <div class="rounded-2xl border border-dashed border-slate-200 bg-white py-12 text-center">
        <p class="text-sm text-slate-400">Você ainda não publicou nenhuma vaga.</p>
        <%= link_to new_job_path, class: "mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
          Publicar primeira vaga
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Seção 2: Vagas que me candidatei ── %>
  <div>
    <h2 class="text-lg font-semibold text-slate-900 mb-4">Vagas que me candidatei</h2>

    <% if @my_proposals.any? %>
      <div class="space-y-3">
        <% @my_proposals.each do |proposal| %>
          <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden transition hover:border-indigo-200">
            <div class="p-5 flex items-start justify-between gap-4">
              <div class="flex gap-3.5 items-start">
                <div class="shrink-0 flex h-10 w-10 items-center justify-center rounded-xl border border-slate-100 bg-slate-50">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                  </svg>
                </div>
                <div>
                  <%= link_to proposal.job, class: "text-sm font-semibold text-slate-900 hover:text-indigo-600 transition" do %>
                    <%= proposal.job.title %>
                  <% end %>
                  <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1">
                    <span class="text-xs text-slate-400">Enviada há <%= time_ago_in_words(proposal.created_at) %></span>
                    <span class="text-slate-200 text-xs">&middot;</span>
                    <span class="text-xs text-slate-500">Sua proposta: <span class="font-medium text-indigo-600"><%= number_to_currency(proposal.value) %></span></span>
                  </div>
                  <% if proposal.message.present? %>
                    <p class="mt-1.5 text-xs text-slate-400 line-clamp-1"><%= proposal.message %></p>
                  <% end %>
                </div>
              </div>

              <%# Status da proposta %>
              <div class="shrink-0">
                <% status_class = case proposal.status
                   when "accepted" then "bg-emerald-50 text-emerald-700 border-emerald-200"
                   when "rejected" then "bg-red-50 text-red-600 border-red-200"
                   else "bg-amber-50 text-amber-700 border-amber-200"
                   end %>
                <% status_label = case proposal.status
                   when "accepted" then "Aceita"
                   when "rejected" then "Recusada"
                   else "Aguardando"
                   end %>
                <span class="inline-flex items-center text-xs font-medium px-2.5 py-1 rounded-full border <%= status_class %>">
                  <%= status_label %>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      </div>

    <% else %>
      <div class="rounded-2xl border border-dashed border-slate-200 bg-white py-12 text-center">
        <p class="text-sm text-slate-400">Você ainda não se candidatou a nenhuma vaga.</p>
        <%= link_to jobs_path, class: "mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600 hover:text-indigo-700" do %>
          Ver vagas disponíveis
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        <% end %>
      </div>
    <% end %>
  </div>

</div>