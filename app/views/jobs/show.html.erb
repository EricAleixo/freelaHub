<% content_for :title, "#{@job.title} · FreelaHub" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">

  <%# ── Notice ── %>
  <% if notice.present? %>
    <p class="mb-5 inline-flex items-center gap-2 py-2 px-3.5 bg-emerald-50 text-emerald-600 text-sm font-medium rounded-lg" id="notice">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <%= notice %>
    </p>
  <% end %>

  <%# ── Card principal ── %>
  <div class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-8">

    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <% status_styles = {
             "draft"  => "bg-slate-100 text-slate-600",
             "open"   => "bg-emerald-50 text-emerald-600",
             "paused" => "bg-amber-50 text-amber-600",
             "closed" => "bg-slate-100 text-slate-500"
           } %>
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium <%= status_styles[@job.status] %> mb-3">
          <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
          <%= @job.status.titleize %>
        </span>
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight"><%= @job.title %></h1>
        <p class="text-sm text-slate-400 mt-1">Posted on <%= @job.created_at.strftime("%b %d, %Y") %></p>
      </div>

      <%= link_to edit_job_path(@job), title: "Edit",
            class: "shrink-0 w-9 h-9 rounded-lg border border-slate-200 flex items-center justify-center text-slate-400 hover:text-slate-700 hover:bg-slate-50 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/>
        </svg>
      <% end %>
    </div>

    <%# ── Métricas rápidas ── %>
    <div class="grid grid-cols-2 gap-4 mb-7">
      <div class="bg-slate-50 rounded-xl p-4">
        <p class="text-xs text-slate-400 mb-1">Budget</p>
        <p class="text-lg font-semibold text-slate-900">
          <%= @job.budget.present? ? number_to_currency(@job.budget) : "Not specified" %>
        </p>
      </div>
      <div class="bg-slate-50 rounded-xl p-4">
        <p class="text-xs text-slate-400 mb-1">Proposals received</p>
        <p class="text-lg font-semibold text-indigo-600"><%= @job.proposals.size %></p>
      </div>
    </div>

    <%# ── Descrição ── %>
    <div>
      <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-3">Description</h2>
      <p class="text-sm text-slate-700 leading-relaxed whitespace-pre-line"><%= @job.description %></p>
    </div>
  </div>

  <%# ── Proposals recebidas ── %>
  <div class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 mt-6">
    <h2 class="text-lg font-semibold text-slate-900 mb-5">Proposals</h2>

    <% if @job.proposals.any? %>
      <ul class="divide-y divide-slate-100">
        <% @job.proposals.each do |proposal| %>
          <li class="py-4 flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <p class="text-sm text-slate-700 line-clamp-2"><%= proposal.message %></p>
              <p class="text-xs text-slate-400 mt-1">
                Sent <%= time_ago_in_words(proposal.created_at) %> ago · <%= proposal.status.to_s.titleize %>
              </p>
            </div>
            <p class="font-semibold text-slate-900 shrink-0">
              <%= number_to_currency(proposal.value) %>
            </p>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-slate-400">No proposals received yet.</p>
    <% end %>
  </div>

  <%# ── Ações ── %>
  <div class="flex items-center justify-end gap-3 mt-6">
    <%= button_to "Delete job", @job, method: :delete,
          form_class: "inline-block",
          class: "px-5 py-2.5 text-sm font-medium text-red-600 hover:bg-red-50 rounded-xl transition cursor-pointer",
          data: { turbo_confirm: "Remove \"#{@job.title}\"? This can't be undone." } %>
    <%= link_to "Edit job", edit_job_path(@job),
          class: "px-5 py-2.5 bg-indigo-500 hover:bg-indigo-600 active:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition shadow-sm shadow-indigo-200" %>
  </div>

</div>