<% content_for :title, "#{@job.title} · FreelaHub" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">

  <%# ── Notice ── %>
  <% if notice.present? %>
    <p class="mb-5 inline-flex items-center gap-2 py-2 px-3.5 bg-emerald-50 text-emerald-600 text-sm font-medium rounded-lg" id="notice">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <%= notice %>
    </p>
  <% end %>

  <%# ── Card principal ── %>
  <%= render @job %>

  <%# ── Propostas recebidas (só para o dono) ── %>
  <% if policy(@job).edit? %>
    <div class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 mt-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-semibold text-slate-900">Propostas recebidas</h2>
        <span class="text-xs text-slate-500 bg-slate-100 rounded-full px-3 py-1">
          <%= pluralize(@job.proposals.count, "proposta") %>
        </span>
      </div>

      <% if @job.proposals.any? %>
        <ul class="divide-y divide-slate-100">
          <% @job.proposals.order(created_at: :desc).each do |proposal| %>
            <% profile = proposal.profile %>
            <% user = profile.user %>
            <% initials = user.full_name.present? ? user.full_name.split.first(2).map { |n| n[0] }.join.upcase : user.name[0..1].upcase %>

            <li class="py-5 flex items-start gap-4">
              <%# Avatar com iniciais %>
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-indigo-50 border border-indigo-100 flex items-center justify-center text-sm font-medium text-indigo-600">
                <%= initials %>
              </div>

              <div class="flex-1 min-w-0">
                <%# Cabeçalho: nome + valor %>
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <span class="text-sm font-semibold text-slate-900">
                      <%= user.full_name.presence || user.name %>
                    </span>
                    <% if user.username.present? %>
                      <span class="text-xs text-slate-400 ml-1.5">@<%= user.username %></span>
                    <% end %>
                  </div>
                  <span class="text-sm font-semibold text-emerald-600 whitespace-nowrap">
                    <%= number_to_currency(proposal.value) %>
                  </span>
                </div>

                <%# Metadados: curso, instituição, status, tempo %>
                <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-1.5">
                  <%= render "proposals/status_badge", proposal: proposal %>
                  <% if profile.course.present? || profile.institution.present? %>
                    <span class="text-xs text-slate-400">&middot;</span>
                    <span class="text-xs text-slate-500">
                      <%= [profile.course, profile.institution].compact.join(" · ") %>
                    </span>
                  <% end %>
                  <span class="text-xs text-slate-400">&middot;</span>
                  <span class="text-xs text-slate-400">
                    há <%= time_ago_in_words(proposal.created_at) %>
                  </span>
                </div>

                <%# Links do perfil (GitHub / LinkedIn) %>
                <% if profile.github.present? || profile.linkedin.present? %>
                  <div class="flex items-center gap-3 mt-2">
                    <% if profile.github.present? %>
                      <%= link_to profile.github, target: "_blank", rel: "noopener",
                            class: "text-xs text-slate-400 hover:text-slate-700 transition flex items-center gap-1" do %>
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                        </svg>
                        GitHub
                      <% end %>
                    <% end %>
                    <% if profile.linkedin.present? %>
                      <%= link_to profile.linkedin, target: "_blank", rel: "noopener",
                            class: "text-xs text-slate-400 hover:text-slate-700 transition flex items-center gap-1" do %>
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                        LinkedIn
                      <% end %>
                    <% end %>
                  </div>
                <% end %>

                <%# Mensagem da proposta %>
                <p class="mt-3 text-sm text-slate-600 leading-relaxed"><%= proposal.message %></p>

                <%# Ações: aceitar/recusar (só dono, proposta pendente) %>
                <% if proposal.status == "pending" %>
                  <div class="flex items-center gap-2 mt-4">
                    <%= button_to "Aceitar proposta",
                          accept_job_proposal_path(@job, proposal),
                          method: :patch,
                          class: "text-xs font-medium px-3 py-1.5 rounded-lg bg-emerald-50 text-emerald-700 border border-emerald-200 hover:bg-emerald-100 transition" %>
                    <%= button_to "Recusar",
                          reject_job_proposal_path(@job, proposal),
                          method: :patch,
                          class: "text-xs font-medium px-3 py-1.5 rounded-lg bg-red-50 text-red-600 border border-red-200 hover:bg-red-100 transition" %>
                    <%= link_to "Ver perfil",
                          profile_path(profile),
                          class: "ml-auto text-xs font-medium px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 hover:border-slate-300 transition" %>
                  </div>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>

      <% else %>
        <div class="text-center py-10">
          <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
          </div>
          <p class="text-sm text-slate-500">Nenhuma proposta recebida ainda.</p>
          <p class="text-xs text-slate-400 mt-1">Quando alguém enviar uma proposta, ela aparecerá aqui.</p>
        </div>
      <% end %>
    </div>

    <%# ── Ações do dono (editar/excluir) ── %>
    <div class="flex items-center justify-end gap-3 mt-6">
      <%= button_to "Excluir vaga", @job,
            method: :delete,
            form_class: "inline-block",
            class: "px-5 py-2.5 text-sm font-medium text-red-600 hover:bg-red-50 rounded-xl transition cursor-pointer",
            data: { turbo_confirm: "Remover \"#{@job.title}\"? Essa ação não pode ser desfeita." } %>
      <%= link_to "Editar vaga", edit_job_path(@job),
            class: "px-5 py-2.5 bg-indigo-500 hover:bg-indigo-600 active:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition" %>
    </div>
  <% end %>

</div>