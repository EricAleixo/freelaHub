<% content_for :title, "Edit job · FreelaHub" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">

  <%# ── Header ── %>
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Edit job</h1>
    <p class="text-slate-500 text-sm mt-1.5">
      Update the details of "<%= @job.title %>".
    </p>
  </div>

  <%# ── Card do formulário ── %>
  <div class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-8">
    <%= render "form", job: @job %>
  </div>

  <%# ── Links secundários ── %>
  <div class="flex items-center gap-4 mt-5 text-sm">
    <%= link_to "View job page", @job, class: "text-slate-500 hover:text-slate-700 transition" %>
    <span class="text-slate-300">·</span>
    <%= link_to "Back to all jobs", jobs_path, class: "text-slate-500 hover:text-slate-700 transition" %>
  </div>

</div>