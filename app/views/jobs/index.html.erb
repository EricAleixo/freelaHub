<% content_for :title, "Vagas · FreelaHub" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <% if notice.present? %>
    <div id="notice" class="mb-6 flex items-center gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <%= notice %>
    </div>
  <% end %>

  <%# Cabeçalho %>
  <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-900">Vagas disponíveis</h1>
      <p class="mt-2 text-slate-500">Encontre oportunidades e envie sua proposta.</p>
    </div>

    <%= link_to my_jobs_jobs_path,
          class: "inline-flex items-center justify-center gap-2 rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-indigo-200 hover:text-indigo-600" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
      </svg>
      Minhas vagas
    <% end %>
  </div>

  <%# Cards de vagas %>
  <% if @jobs.any? %>
    <div class="space-y-4">
      <% @jobs.each do |job| %>
        <div class="rounded-2xl border border-slate-200 bg-white transition hover:border-indigo-200 overflow-hidden">
          <div class="p-5 sm:p-6">
            <div class="flex items-start justify-between gap-4">

              <div class="flex gap-3.5 items-start">
                <div class="shrink-0 flex h-12 w-12 items-center justify-center rounded-xl border border-indigo-100 bg-indigo-50">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>

                <div>
                  <%= link_to job, class: "text-base font-semibold text-slate-900 hover:text-indigo-600 transition leading-snug" do %>
                    <%= job.title %>
                  <% end %>

                  <div class="mt-1.5 flex flex-wrap items-center gap-x-2 gap-y-1">
                    <div class="flex items-center gap-1.5">
                      <div class="flex h-5 w-5 items-center justify-center rounded-full bg-indigo-50 text-indigo-500 text-[9px] font-semibold border border-indigo-100">
                        <%= job.user.full_name.first(2).upcase %>
                      </div>
                      <span class="text-xs text-slate-600"><%= job.user.full_name %></span>
                    </div>
                    <span class="text-slate-300 text-xs">&middot;</span>
                    <span class="text-xs text-slate-400">há <%= time_ago_in_words(job.created_at) %></span>
                  </div>

                  <div class="mt-2.5">
                    <span class="<%= job.status_badge_class %>"><%= job.human_status %></span>
                    <% if job.proposals.exists?(profile_id: current_user.profile.id) %>
                      <span class="inline-flex items-center gap-1 rounded-full bg-indigo-100 px-2.5 py-1 text-xs font-medium text-indigo-700">Proposta feita</span>
                    <% end %>
                  </div>
                </div>
              </div>

              <%= link_to job,
                    class: "shrink-0 flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:border-slate-300 hover:text-slate-700 hover:bg-slate-50 transition",
                    title: "Ver detalhes" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.065 7-9.542 7S3.732 16.057 2.458 12z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              <% end %>
            </div>

            <% if job.description.present? %>
              <p class="mt-4 text-sm text-slate-500 leading-relaxed line-clamp-2"><%= job.description %></p>
            <% end %>
          </div>

          <div class="grid grid-cols-3 divide-x divide-slate-100 border-t border-slate-100 bg-slate-50/60">
            <div class="py-3.5 text-center">
              <p class="text-sm font-semibold text-indigo-600"><%= job.budget.present? ? number_to_currency(job.budget) : "—" %></p>
              <p class="mt-0.5 text-xs text-slate-400">Orçamento</p>
            </div>
            <div class="py-3.5 text-center">
              <p class="text-sm font-semibold text-indigo-600"><%= job.proposals.count %></p>
              <p class="mt-0.5 text-xs text-slate-400">Propostas</p>
            </div>
            <div class="py-3.5 text-center">
              <p class="text-sm font-semibold text-indigo-600"><%= l(job.created_at.to_date) %></p>
              <p class="mt-0.5 text-xs text-slate-400">Publicada em</p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <div class="rounded-2xl border border-dashed border-slate-300 bg-white py-20">
      <div class="mx-auto max-w-sm text-center">
        <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z"/>
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-slate-900">Nenhuma vaga disponível</h2>
        <p class="mt-2 text-sm text-slate-500 leading-relaxed">
          Ainda não há vagas abertas no momento.<br>
          Volte em breve para conferir novas oportunidades.
        </p>
      </div>
    </div>
  <% end %>

</div>