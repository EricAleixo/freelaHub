<% content_for :title, "Jobs · FreelaHub" %>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <% if notice.present? %>
    <div id="notice"
         class="mb-6 flex items-center gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
      <svg xmlns="http://www.w3.org/2000/svg"
           class="h-5 w-5"
           fill="none"
           viewBox="0 0 24 24"
           stroke="currentColor"
           stroke-width="2">
        <path stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>

      <%= notice %>
    </div>
  <% end %>

  <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between mb-8">

    <div>
      <h1 class="text-3xl font-bold text-slate-900">
        Minhas vagas
      </h1>

      <p class="mt-2 text-slate-500">
        Gerencie suas vagas e acompanhe as propostas recebidas.
      </p>
    </div>

    <%= link_to new_job_path,
        class: "inline-flex items-center justify-center gap-2 rounded-xl bg-indigo-600 px-5 py-3 font-semibold text-white transition hover:bg-indigo-700" do %>

      <svg xmlns="http://www.w3.org/2000/svg"
           class="h-5 w-5"
           fill="none"
           viewBox="0 0 24 24"
           stroke="currentColor"
           stroke-width="2.5">
        <path stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 4.5v15m7.5-7.5h-15"/>
      </svg>

      Publicar vaga

    <% end %>

  </div>

  <div class="grid gap-5 sm:grid-cols-3 mb-8">

    <div class="rounded-2xl border border-slate-200 bg-white p-6">

      <p class="text-sm text-slate-500">
        Vagas abertas
      </p>

      <h2 class="mt-3 text-4xl font-bold text-indigo-600">
        <%= @jobs.count(&:open?) %>
      </h2>

    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6">

      <p class="text-sm text-slate-500">
        Total de propostas
      </p>

      <h2 class="mt-3 text-4xl font-bold text-slate-900">
        <%= @jobs.sum { |job| job.proposals.count } %>
      </h2>

    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6">

      <p class="text-sm text-slate-500">
        Total de vagas
      </p>

      <h2 class="mt-3 text-4xl font-bold text-slate-900">
        <%= @jobs.count %>
      </h2>

    </div>

  </div>

  <% if @jobs.any? %>

    <div class="space-y-5">

      <% @jobs.each do |job| %>

        <div class="rounded-2xl border border-slate-200 bg-white transition hover:border-indigo-200 hover:shadow-md">

          <div class="p-6">

            <div class="flex items-start justify-between gap-5">

              <div class="flex gap-4">

                <div class="flex h-14 w-14 items-center justify-center rounded-xl border border-indigo-100 bg-indigo-50">

                  <svg xmlns="http://www.w3.org/2000/svg"
                       class="h-7 w-7 text-indigo-500"
                       fill="none"
                       viewBox="0 0 24 24"
                       stroke="currentColor"
                       stroke-width="2">
                    <path stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>

                </div>

                <div>

                  <%= link_to job,
                      class: "text-xl font-semibold text-slate-900 hover:text-indigo-600 transition" do %>

                    <%= job.title %>

                  <% end %>

                  <p class="mt-1 text-sm text-slate-500">
                    Publicada
                    <%= time_ago_in_words(job.created_at) %>
                    atrás
                  </p>

                  <div class="mt-3">
                    <span class="<%= job.status_badge_class %>">
                      <%= job.human_status %>
                    </span>
                  </div>

                </div>

              </div>
                            <div class="flex items-center gap-2">

                <%= link_to job,
                    class: "flex h-10 w-10 items-center justify-center rounded-lg text-slate-500 transition hover:bg-slate-100 hover:text-slate-800",
                    title: "Visualizar" do %>

                  <svg xmlns="http://www.w3.org/2000/svg"
                       class="h-5 w-5"
                       fill="none"
                       viewBox="0 0 24 24"
                       stroke="currentColor"
                       stroke-width="2">
                    <path stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M2.458 12C3.732 7.943 7.523 5 12 5s8.268 2.943 9.542 7c-1.274 4.057-5.065 7-9.542 7S3.732 16.057 2.458 12z"/>
                    <path stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>

                <% end %>

                <%= link_to edit_job_path(job),
                    class: "flex h-10 w-10 items-center justify-center rounded-lg text-slate-500 transition hover:bg-slate-100 hover:text-slate-800",
                    title: "Editar" do %>

                  <svg xmlns="http://www.w3.org/2000/svg"
                       class="h-5 w-5"
                       fill="none"
                       viewBox="0 0 24 24"
                       stroke="currentColor"
                       stroke-width="2">
                    <path stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/>
                  </svg>

                <% end %>

                <%= button_to job,
                    method: :delete,
                    form: {
                      data: {
                        turbo_confirm: "Excluir \"#{job.title}\"?"
                      }
                    },
                    class: "flex h-10 w-10 items-center justify-center rounded-lg text-slate-500 transition hover:bg-red-50 hover:text-red-600",
                    title: "Excluir" do %>

                  <svg xmlns="http://www.w3.org/2000/svg"
                       class="h-5 w-5"
                       fill="none"
                       viewBox="0 0 24 24"
                       stroke="currentColor"
                       stroke-width="2">
                    <path stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
                  </svg>

                <% end %>

              </div>

            </div>

            <% if job.description.present? %>

              <p class="mt-5 line-clamp-2 leading-7 text-slate-600">
                <%= job.description %>
              </p>

            <% end %>

          </div>

          <div class="grid grid-cols-3 border-t border-slate-200 bg-slate-50">

            <div class="py-4 text-center border-r border-slate-200">
              <p class="font-semibold text-indigo-600">
                <%= job.budget.present? ? number_to_currency(job.budget) : "—" %>
              </p>
              <p class="mt-1 text-xs text-slate-500">
                Orçamento
              </p>
            </div>

            <div class="py-4 text-center border-r border-slate-200">
              <p class="font-semibold text-indigo-600">
                <%= job.proposals.count %>
              </p>
              <p class="mt-1 text-xs text-slate-500">
                Propostas
              </p>
            </div>

            <div class="py-4 text-center">
              <p class="font-semibold text-indigo-600">
                <%= l(job.created_at.to_date) %>
              </p>
              <p class="mt-1 text-xs text-slate-500">
                Publicada
              </p>
            </div>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="rounded-2xl border border-dashed border-slate-300 bg-white py-20">

      <div class="mx-auto max-w-sm text-center">

        <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100">

          <svg xmlns="http://www.w3.org/2000/svg"
               class="h-8 w-8 text-slate-400"
               fill="none"
               viewBox="0 0 24 24"
               stroke="currentColor"
               stroke-width="1.8">
            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0A2.25 2.25 0 0021 12.49V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006A23.978 23.978 0 0112 15.75a23.978 23.978 0 01-8.25-1.6"/>
          </svg>

        </div>

        <h2 class="text-xl font-semibold text-slate-900">
          Nenhuma vaga publicada
        </h2>

        <p class="mt-2 text-slate-500">
          Crie sua primeira vaga e comece a receber propostas de profissionais.
        </p>

        <%= link_to new_job_path,
            class: "mt-8 inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-5 py-3 font-semibold text-white transition hover:bg-indigo-700" do %>

          <svg xmlns="http://www.w3.org/2000/svg"
               class="h-5 w-5"
               fill="none"
               viewBox="0 0 24 24"
               stroke="currentColor"
               stroke-width="2">
            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>

          Publicar vaga

        <% end %>

      </div>

    </div>

  <% end %>

</div>